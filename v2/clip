## SECTION 5: AUTHORIZATION — CASL + SoD

RLS is the hard boundary. CASL is the *UX* layer — it decides what buttons render and fails requests early with useful errors.

```typescript
// packages/policy/src/ability.ts
import { AbilityBuilder, createMongoAbility, type MongoAbility } from '@casl/ability';
import type { Session } from '@intune/auth';

type Actions = 'read' | 'create' | 'update' | 'delete' | 'approve' | 'issue' | 'revoke' | 'file';
type Subjects =
  | 'Client' | 'KycCase' | 'SarCase' | 'ScreeningHit' | 'Engagement' | 'Project'
  | 'Case' | 'CaseNote' | 'Workpaper' | 'Assessment' | 'Finding' | 'Certificate'
  | 'Document' | 'Policy' | 'User' | 'all';

export type AppAbility = MongoAbility<[Actions, Subjects]>;

export function defineAbility(s: Session): AppAbility {
  const { can, cannot, build } = new AbilityBuilder<AppAbility>(createMongoAbility);
  const has = (p: string) => s.permissions.includes(p);

  if (s.isStaff) {
    can('read', ['Client', 'Engagement', 'Project', 'Document']);

    if (has('intake.kyc.read')) can('read', 'KycCase');
    if (has('intake.kyc.write')) can(['create', 'update'], 'KycCase');
    if (has('intake.kyc.approve')) can('approve', 'KycCase');
    if (has('intake.sar.read')) can('read', 'SarCase');
    if (has('intake.sar.file')) can('file', 'SarCase');
    if (has('intake.screening.disposition')) can('update', 'ScreeningHit');

    if (has('frame.workpaper.prepare'))
      can(['create', 'update'], 'Workpaper', { preparedBy: s.userId, isLocked: false });
    // Four-eyes at the object level: cannot review your own work
    if (has('frame.workpaper.review'))
      can('approve', 'Workpaper', { preparedBy: { $ne: s.userId } });

    if (has('frame.assessment.issue')) can('issue', 'Assessment');
    if (has('frame.certificate.issue')) can('issue', 'Certificate');
    if (has('frame.certificate.revoke')) can('revoke', 'Certificate');
    if (has('gov.policy.approve')) can('approve', 'Policy');
    if (has('core.user.admin')) can(['create', 'update'], 'User');

    if (!has('engage.case.confidential')) cannot('read', 'Case', { isConfidential: true });
    if (!has('engage.note.privileged')) cannot('read', 'CaseNote', { isPrivileged: true });

    cannot('delete', 'all');   // soft-delete only, everywhere
  } else {
    const ids = s.visibleClientIds;
    can('read', 'Client', { clientId: { $in: ids } });
    can('read', 'Document', {
      clientId: { $in: ids },
      classification: { $in: ['public', 'confidential'] },
    });
    can('read', 'Engagement', { clientId: { $in: ids } });
    cannot('read', ['KycCase', 'SarCase', 'Workpaper', 'CaseNote', 'Policy']);
  }

  return build();
}
```

