'use server';

import { z } from 'zod';
import { sql } from 'drizzle-orm';
import { staffAction, ForbiddenError } from '@/lib/safe-action';
import { enqueue } from '@intune/jobs';

const approveSchema = z.object({
  kycCaseId: z.string().uuid(),
  decision: z.enum(['approved', 'rejected']),
  rationale: z.string().min(30, 'A decision rationale is required for the audit trail.'),
});

export const decideKycCase = staffAction
  .metadata({ name: 'kyc.decide' })
  .schema(approveSchema)
  .action(async ({ parsedInput: input, ctx }) => {
    if (!ctx.ability.can('approve', 'KycCase')) {
      throw new ForbiddenError('You lack KYC approval authority.');
    }

    return ctx.db(async (tx) => {
      const [kc] = await tx.execute(sql`
        SELECT kyc_case_id, client_id, reviewed_by, risk_rating::text AS risk, status::text
          FROM intake.kyc_case WHERE kyc_case_id = ${input.kycCaseId}
      `).then((r) => r.rows as any[]);

      if (!kc) throw new ForbiddenError('Case not found.');
      if (kc.reviewed_by === ctx.session.userId) {
        throw new ForbiddenError(
          'Four-eyes violation: you reviewed this case and cannot also approve it.',
        );
      }

      // Unresolved sanctions hits block approval outright
      const [{ pending }] = await tx.execute(sql`
        SELECT count(*)::int AS pending
          FROM intake.screening_hit h
          JOIN intake.screening_run r ON r.screening_id = h.screening_id
         WHERE r.kyc_case_id = ${input.kycCaseId} AND h.disposition = 'pending'
      `).then((r) => r.rows as any[]);

      if (pending > 0 && input.decision === 'approved') {
        throw new ForbiddenError(
          `${pending} screening hit(s) remain undispositioned. Resolve before approval.`,
        );
      }

      const cadence: Record<string, number> = {
        critical: 90, high: 180, elevated: 365, moderate: 730, low: 1095,
      };

      await tx.execute(sql`
        UPDATE intake.kyc_case
           SET status = ${input.decision}::intake.kyc_status,
               approved_by = ${ctx.session.userId},
               decided_at = now(),
               decision_rationale = ${input.rationale},
               next_review_due = CASE WHEN ${input.decision} = 'approved'
                 THEN CURRENT_DATE + ${cadence[kc.risk ?? 'moderate'] ?? 730}
                 ELSE NULL END
         WHERE kyc_case_id = ${input.kycCaseId}
      `);

      if (input.decision === 'approved') {
        await tx.execute(sql`
          UPDATE crm.client SET record_status = 'active', onboarded_at = coalesce(onboarded_at, now())
           WHERE client_id = ${kc.client_id}
        `);
      }

      await enqueue('notification.send', {
        tenantId: ctx.session.tenantId,
        template: 'kyc_decision',
        payload: { kycCaseId: input.kycCaseId, decision: input.decision },
      });

      return { ok: true as const };
    });
  });
