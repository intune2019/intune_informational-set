// packages/auth/src/mfa.ts
import { authenticator } from 'otplib';
import { randomBytes, createHash } from 'node:crypto';
import { encryptField, decryptField } from '@intune/crypto';
import { withActor } from '@intune/db';
import { sql } from 'drizzle-orm';

authenticator.options = { window: 1, step: 30 };

export async function enrollTotp(userId: string, tenantId: string, email: string) {
  const secret = authenticator.generateSecret(32);
  const uri = authenticator.keyuri(email, 'In.Tune ERP', secret);

  const recoveryCodes = Array.from({ length: 10 }, () =>
    randomBytes(5).toString('hex').toUpperCase().match(/.{1,5}/g)!.join('-'));
  const hashed = recoveryCodes.map((c) =>
    createHash('sha256').update(c.replace(/-/g, '')).digest('hex'));

  await withActor({ actorId: userId, tenantId }, async (tx) => {
    await tx.execute(sql`
      INSERT INTO core.user_mfa (user_id, method, secret_enc, recovery_hashes, enrolled_at)
      VALUES (${userId}, 'totp', ${await encryptField(secret)}, ${hashed}, NULL)
      ON CONFLICT (user_id, method) DO UPDATE
        SET secret_enc = EXCLUDED.secret_enc,
            recovery_hashes = EXCLUDED.recovery_hashes,
            enrolled_at = NULL
    `);
  });

  return { uri, recoveryCodes }; // shown exactly once
}

export async function verifyTotp(userId: string, tenantId: string, token: string) {
  return withActor({ actorId: userId, tenantId }, async (tx) => {
    const [row] = await tx.execute(sql`
      SELECT secret_enc, recovery_hashes, last_used_counter
        FROM core.user_mfa WHERE user_id = ${userId} AND method = 'totp'
    `).then((r) => r.rows as any[]);
    if (!row) return false;

    const secret = await decryptField(row.secret_enc);

    if (authenticator.verify({ token, secret })) {
      const counter = Math.floor(Date.now() / 1000 / 30);
      // Replay guard — a given TOTP window is usable once
      if (row.last_used_counter && Number(row.last_used_counter) >= counter) return false;
      await tx.execute(sql`
        UPDATE core.user_mfa SET last_used_counter = ${counter}, enrolled_at = coalesce(enrolled_at, now())
         WHERE user_id = ${userId} AND method = 'totp'
      `);
      await tx.execute(sql`UPDATE core.app_user SET mfa_enrolled = true WHERE user_id = ${userId}`);
      return true;
    }

    // Recovery code path — single use, removed on consumption
    const h = createHash('sha256').update(token.replace(/-/g, '').toUpperCase()).digest('hex');
    if ((row.recovery_hashes as string[])?.includes(h)) {
      await tx.execute(sql`
        UPDATE core.user_mfa SET recovery_hashes = array_remove(recovery_hashes, ${h})
         WHERE user_id = ${userId} AND method = 'totp'
      `);
      return true;
    }
    return false;
  });
}
