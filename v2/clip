## SECTION 3: DATABASE LAYER — RLS-SCOPED CLIENT

This is the most important file in the codebase. Everything else depends on it being correct.

```typescript
// packages/db/src/client.ts
import { drizzle, type NodePgDatabase } from 'drizzle-orm/node-postgres';
import { Pool, type PoolClient } from 'pg';
import { sql } from 'drizzle-orm';
import * as schema from './schema/index.js';

// ── Admin pool: migrations, cron, system tasks. BYPASSES RLS. Never web-facing.
const adminPool = new Pool({
  connectionString: process.env.DATABASE_URL_ADMIN,
  max: 5,
  ssl: { rejectUnauthorized: true, ca: process.env.PG_CA_CERT },
});

// ── App pool: every request. Role has NO BYPASSRLS.
const appPool = new Pool({
  connectionString: process.env.DATABASE_URL_APP,
  max: Number(process.env.PG_POOL_MAX ?? 20),
  idleTimeoutMillis: 30_000,
  connectionTimeoutMillis: 5_000,
  statement_timeout: 30_000,
  ssl: { rejectUnauthorized: true, ca: process.env.PG_CA_CERT },
});

export const dbAdmin: NodePgDatabase<typeof schema> = drizzle(adminPool, { schema });

export interface ActorContext {
  actorId: string;
  tenantId: string;
  requestId?: string;
  clientIp?: string;
}

/**
 * Runs `fn` inside a transaction with session GUCs bound to the actor.
 * set_config(..., true) = transaction-local → cannot leak across pooled connections.
 * This is the ONLY sanctioned path for request-scoped DB access.
 */
export async function withActor<T>(
  ctx: ActorContext,
  fn: (tx: NodePgDatabase<typeof schema>) => Promise<T>,
): Promise<T> {
  const conn: PoolClient = await appPool.connect();
  try {
    await conn.query('BEGIN');
    await conn.query(
      `SELECT set_config('app.actor_id', $1, true),
              set_config('app.tenant_id', $2, true),
              set_config('app.request_id', $3, true)`,
      [ctx.actorId, ctx.tenantId, ctx.requestId ?? ''],
    );
    const tx = drizzle(conn, { schema });
    const result = await fn(tx);
    await conn.query('COMMIT');
    return result;
  } catch (err) {
    await conn.query('ROLLBACK').catch(() => {});
    throw err;
  } finally {
    conn.release();
  }
}

/** Unauthenticated reads (login lookup, share-link resolution). Explicit and rare. */
export async function withAnon<T>(
  fn: (tx: NodePgDatabase<typeof schema>) => Promise<T>,
): Promise<T> {
  const conn = await appPool.connect();
  try {
    await conn.query('BEGIN');
    await conn.query(`SELECT set_config('app.actor_id', '', true)`);
    const r = await fn(drizzle(conn, { schema }));
    await conn.query('COMMIT');
    return r;
  } catch (e) {
    await conn.query('ROLLBACK').catch(() => {});
    throw e;
  } finally {
    conn.release();
  }
}

export async function healthcheck(): Promise<boolean> {
  try {
    const r = await appPool.query('SELECT 1 AS ok');
    return r.rows[0]?.ok === 1;
  } catch {
    return false;
  }
}

export async function shutdown() {
  await Promise.all([appPool.end(), adminPool.end()]);
}

export { schema, sql };
export type Db = NodePgDatabase<typeof schema>;
```

