// apps/web/src/server/actions/workpaper.ts
'use server';

import { z } from 'zod';
import { revalidatePath } from 'next/cache';
import { sql } from 'drizzle-orm';
import { staffAction, ForbiddenError } from '@/lib/safe-action';
import { subject } from '@casl/ability';

const concludeSchema = z.object({
  workpaperId: z.string().uuid(),
  result: z.enum(['effective', 'partially_effective', 'deficient', 'critical_exposure']),
  conclusion: z.string().min(20, 'A conclusion must be substantive.'),
  exceptionsNoted: z.number().int().min(0).default(0),
});

/**
 * ICAEF™: Evidence Before Conclusion.
 * We pre-check for a useful error, but the DB trigger is the actual enforcement —
 * it cannot be bypassed by any caller, including a compromised app server.
 */
export const concludeWorkpaper = staffAction
  .metadata({ name: 'workpaper.conclude' })
  .schema(concludeSchema)
  .action(async ({ parsedInput: input, ctx }) => {
    return ctx.db(async (tx) => {
      const [wp] = await tx.execute(sql`
        SELECT wp.workpaper_id, wp.wp_reference, wp.prepared_by, wp.is_locked,
               tp.min_evidence_tier::text AS min_tier,
               (SELECT count(*) FROM frame.evidence e
                 WHERE e.workpaper_id = wp.workpaper_id AND e.is_sufficient IS TRUE)
                 AS sufficient_evidence
          FROM frame.workpaper wp
          JOIN frame.test_procedure tp ON tp.procedure_id = wp.procedure_id
         WHERE wp.workpaper_id = ${input.workpaperId}
      `).then((r) => r.rows as any[]);

      if (!wp) throw new ForbiddenError('Workpaper not found or not visible.');
      if (wp.is_locked) throw new ForbiddenError('Workpaper is locked; reopen it first.');

      if (!ctx.ability.can('update', subject('Workpaper', {
        preparedBy: wp.prepared_by, isLocked: wp.is_locked,
      }))) {
        throw new ForbiddenError('You may not modify this workpaper.');
      }

      if (Number(wp.sufficient_evidence) === 0) {
        throw new ForbiddenError(
          `Cannot conclude ${wp.wp_reference}: no sufficient evidence attached. ` +
          `ICAEF requires at least one ${wp.min_tier} or stronger item marked sufficient.`,
        );
      }

      await tx.execute(sql`
        UPDATE frame.workpaper
           SET result = ${input.result}::frame.exam_rating,
               conclusion = ${input.conclusion},
               exceptions_noted = ${input.exceptionsNoted},
               prepared_at = coalesce(prepared_at, now())
         WHERE workpaper_id = ${input.workpaperId}
      `);

      revalidatePath(`/assessments/[id]/workpapers`, 'page');
      return { ok: true as const, reference: wp.wp_reference };
    });
  });

const reviewSchema = z.object({
  workpaperId: z.string().uuid(),
  approve: z.boolean(),
  reviewNotes: z.string().optional(),
});

/** Four-eyes: DB CHECK enforces reviewed_by <> prepared_by. Belt and suspenders. */
export const reviewWorkpaper = staffAction
  .metadata({ name: 'workpaper.review' })
  .schema(reviewSchema)
  .action(async ({ parsedInput: input, ctx }) => {
    return ctx.db(async (tx) => {
      const [wp] = await tx.execute(sql`
        SELECT prepared_by, result, wp_reference FROM frame.workpaper
         WHERE workpaper_id = ${input.workpaperId}
      `).then((r) => r.rows as any[]);

      if (!wp) throw new ForbiddenError('Workpaper not found.');
      if (!wp.result) throw new ForbiddenError('Cannot review a workpaper with no conclusion.');

      if (!ctx.ability.can('approve', subject('Workpaper', { preparedBy: wp.prepared_by }))) {
        throw new ForbiddenError(
          'Independence violation: you prepared this workpaper and cannot review it.',
        );
      }

      await tx.execute(sql`
        UPDATE frame.workpaper
           SET reviewed_by = ${ctx.session.userId},
               reviewed_at = now(),
               is_locked = ${input.approve}
         WHERE workpaper_id = ${input.workpaperId}
      `);

      revalidatePath('/assessments');
      return { ok: true as const };
    });
  });
