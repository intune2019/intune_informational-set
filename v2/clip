               d.legal_hold, d.classification
          FROM docs.document_version dv
          JOIN docs.document d ON d.document_id = dv.document_id
         WHERE dv.document_id = ${i.documentId}
           AND dv.version_no = coalesce(${i.versionNo ?? null}, d.current_version)
      `).then((r) => r.rows as any[]);

