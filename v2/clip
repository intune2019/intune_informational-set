import { sendNotification } from './processors/notification.js';
import { scanDocument, embedDocument } from './processors/documents.js';
import { runScreening } from './processors/screening.js';
import { renderReport } from './processors/report.js';
import { shutdown as dbShutdown } from '@intune/db';

const handlers: { [K in keyof JobMap]: (d: JobMap[K]) => Promise<unknown> } = {
  'notification.send': sendNotification,
  'document.scan': scanDocument,
  'document.embed': embedDocument,
  'screening.run': runScreening,
  'report.render': renderReport,
  'certificate.sync': async () => {},
  'kb.reindex': async () => {},
};

const workers = (['default', 'documents', 'screening', 'reports'] as const).map((q) =>
  new Worker(q, async (job) => {
    const h = handlers[job.name as keyof JobMap];
    if (!h) throw new Error(`no handler for ${job.name}`);
    logger.info({ job: job.name, id: job.id }, 'processing');
    return h(job.data as any);
  }, {
    connection,
    concurrency: q === 'documents' ? 4 : 8,
    limiter: q === 'screening' ? { max: 10, duration: 1_000 } : undefined,
  }));

for (const w of workers) {
  w.on('failed', (job, err) =>
    logger.error({ job: job?.name, id: job?.id, attempts: job?.attemptsMade, err }, 'job failed'));
  w.on('completed', (job) => logger.debug({ job: job.name, id: job.id }, 'job completed'));
}

// Notification outbox drain: pg_cron writes rows, this pushes them to BullMQ.
// Decouples DB scheduling from network I/O — the DB never makes an outbound call.
import { dbAdmin, sql } from '@intune/db';
import { enqueue } from '@intune/jobs';

setInterval(async () => {
  try {
    const rows = await dbAdmin.execute(sql`
      UPDATE core.notification
         SET status = 'sent', attempts = attempts + 1
       WHERE notification_id IN (
         SELECT notification_id FROM core.notification
          WHERE status = 'queued' AND send_after <= now() AND attempts < 5
          ORDER BY send_after
          FOR UPDATE SKIP LOCKED
          LIMIT 50)
      RETURNING notification_id, tenant_id, channel, subject, body, payload, user_id
    `);
    for (const n of rows.rows as any[]) {
      await enqueue('notification.send', {
        tenantId: n.tenant_id,
        notificationId: n.notification_id,
        template: n.channel,
        payload: { ...n.payload, subject: n.subject, body: n.body, userId: n.user_id },
      });
    }
  } catch (e) {
    logger.error({ err: e }, 'outbox drain failed');
  }
}, 10_000);

async function gracefulShutdown(sig: string) {
  logger.info({ sig }, 'shutting down worker');
  await Promise.all(workers.map((w) => w.close()));
  await dbShutdown();
  process.exit(0);
}
process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT', () => gracefulShutdown('SIGINT'));
