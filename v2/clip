  S3_BUCKET: intune-documents
  S3_ACCESS_KEY: ${MINIO_ACCESS_KEY}
  S3_SECRET_KEY: ${MINIO_SECRET_KEY}
  CLAMAV_HOST: clamav
  FIELD_ENCRYPTION_KEY: ${FIELD_ENCRYPTION_KEY}
  BLIND_INDEX_PEPPER: ${BLIND_INDEX_PEPPER}
  PG_CA_CERT_FILE: /certs/ca.crt

services:
  postgres:
    image: pgvector/pgvector:pg16
    container_name: intune-pg
    restart: unless-stopped
    shm_size: 1g
    environment:
      POSTGRES_DB: intune
      POSTGRES_USER: intune_admin
      POSTGRES_PASSWORD_FILE: /run/secrets/pg_password
      POSTGRES_INITDB_ARGS: "--data-checksums"
    command: >
      postgres
      -c shared_preload_libraries=pg_cron,pg_stat_statements
      -c cron.database_name=intune
      -c max_connections=200
      -c shared_buffers=2GB
      -c effective_cache_size=6GB
      -c work_mem=16MB
      -c maintenance_work_mem=512MB
      -c wal_level=replica
      -c archive_mode=on
      -c archive_command='pgbackrest --stanza=intune archive-push %p'
      -c log_statement=ddl
      -c log_min_duration_statement=1000
      -c log_connections=on
      -c ssl=on -c ssl_cert_file=/certs/server.crt -c ssl_key_file=/certs/server.key
    volumes:
      - pgdata:/var/lib/postgresql/data
      - ./sql:/docker-entrypoint-initdb.d:ro
      - ./certs:/certs:ro
    secrets: [pg_password]
    networks: [data]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U intune_admin -d intune"]
      interval: 10s
      retries: 5
    logging: *logging

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: >
      redis-server --appendonly yes --requirepass ${REDIS_PASSWORD}
      --maxmemory 1gb --maxmemory-policy noeviction
    volumes: [redisdata:/data]
    networks: [data]
    logging: *logging

  minio:
    image: minio/minio:latest
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ACCESS_KEY}
      MINIO_ROOT_PASSWORD: ${MINIO_SECRET_KEY}
      MINIO_SERVER_URL: https://files.trustintune.com
    volumes: [miniodata:/data]
    networks: [data, app]
    logging: *logging

  clamav:
    image: clamav/clamav:latest
    restart: unless-stopped
    volumes: [clamdb:/var/lib/clamav]
    networks: [data]
    logging: *logging

  web:
    build:
      context: .
      dockerfile: apps/web/Dockerfile
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
      redis: { condition: service_started }
    environment:
      <<: *app-env
      PORT: 3000
      NEXT_PUBLIC_APP_URL: https://erp.trustintune.com
    volumes: [./certs:/certs:ro]
    networks: [data, app]
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:3000/api/v1/health').then(r=>process.exit(r.ok?0:1))"]
      interval: 30s
    deploy:
      replicas: 2
    logging: *logging

  worker:
    build:
      context: .
      dockerfile: apps/worker/Dockerfile
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
      redis: { condition: service_started }
    environment: *app-env
    volumes: [./certs:/certs:ro]
    networks: [data]
    logging: *logging

  metabase:
    image: metabase/metabase:latest
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
    environment:
      MB_DB_TYPE: postgres
      MB_DB_HOST: postgres
      MB_DB_PORT: 5432
      MB_DB_DBNAME: metabase
      MB_DB_USER: metabase_app
      MB_DB_PASS: ${METABASE_DB_PASSWORD}
      MB_ENCRYPTION_SECRET_KEY: ${METABASE_SECRET}
      JAVA_TIMEZONE: America/Denver
    networks: [data, app]
    logging: *logging

  n8n:
    image: n8nio/n8n:latest
    restart: unless-stopped
    depends_on:
      postgres: { condition: service_healthy }
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n_app
      DB_POSTGRESDB_PASSWORD: ${N8N_DB_PASSWORD}
      N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
      N8N_HOST: automation.trustintune.com
      N8N_PROTOCOL: https
      WEBHOOK_URL: https://automation.trustintune.com/
      GENERIC_TIMEZONE: America/Denver
      N8N_DIAGNOSTICS_ENABLED: "false"
    volumes: [n8ndata:/home/node/.n8n]
    networks: [data, app]
    logging: *logging

  pgbackrest:
    image: pgbackrest/pgbackrest:latest
    restart: unless-stopped
    depends_on: [postgres]
    volumes:
      - pgdata:/var/lib/postgresql/data:ro
      - backups:/var/lib/pgbackrest
      - ./pgbackrest.conf:/etc/pgbackrest/pgbackrest.conf:ro
    networks: [data]
    logging: *logging

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports: ["80:80", "443:443"]
    volumes:
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      - ./certs:/etc/nginx/certs:ro
      - nginx_cache:/var/cache/nginx
    depends_on: [web, metabase, n8n]
    networks: [app]
    logging: *logging

volumes:
  pgdata: {}
  redisdata: {}
  miniodata: {}
  clamdb: {}
  n8ndata: {}
  backups: {}
  nginx_cache: {}

networks:
  data: { internal: true }
  app: { driver: bridge }

secrets:
  pg_password:
    file: ./secrets/pg_password.txt
```

