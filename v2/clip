// apps/worker/src/processors/documents.ts
import { createHash } from 'node:crypto';
import net from 'node:net';
import { GetObjectCommand, S3Client } from '@aws-sdk/client-s3';
import { dbAdmin, sql } from '@intune/db';
import { enqueue } from '@intune/jobs';
import type { JobMap } from '@intune/jobs';

const s3 = new S3Client({
  endpoint: process.env.S3_ENDPOINT,
  region: process.env.S3_REGION ?? 'us-east-1',
  forcePathStyle: true,
  credentials: {
    accessKeyId: process.env.S3_ACCESS_KEY!,
    secretAccessKey: process.env.S3_SECRET_KEY!,
  },
});

/** ClamAV INSTREAM over TCP — streams without buffering the whole file. */
function clamScan(stream: NodeJS.ReadableStream): Promise<'clean' | 'infected'> {
  return new Promise((resolve, reject) => {
    const sock = net.createConnection({
      host: process.env.CLAMAV_HOST ?? 'clamav',
      port: Number(process.env.CLAMAV_PORT ?? 3310),
    });
    let out = '';
    sock.on('connect', () => {
      sock.write('zINSTREAM\0');
      stream.on('data', (c: Buffer) => {
        const len = Buffer.alloc(4);
        len.writeUInt32BE(c.length);
        sock.write(len); sock.write(c);
      });
      stream.on('end', () => sock.write(Buffer.alloc(4)));
    });
    sock.on('data', (d) => { out += d.toString(); });
    sock.on('end', () => resolve(out.includes('OK') ? 'clean' : 'infected'));
    sock.on('error', reject);
  });
}

export async function scanDocument(d: JobMap['document.scan']) {
  const [v] = await dbAdmin.execute(sql`
    SELECT version_id, storage_bucket, storage_key
      FROM docs.document_version
     WHERE document_id = ${d.documentId} AND version_no = ${d.version}
  `).then((r) => r.rows as any[]);
  if (!v) throw new Error(`version not found: ${d.documentId} v${d.version}`);

  const obj = await s3.send(new GetObjectCommand({ Bucket: v.storage_bucket, Key: v.storage_key }));
  const body = obj.Body as NodeJS.ReadableStream;

  // Tee the stream: hash and scan in one pass
  const hash = createHash('sha256');
  body.on('data', (c: Buffer) => hash.update(c));
  const verdict = await clamScan(body);
  const digest = hash.digest('hex');

  await dbAdmin.execute(sql`
    UPDATE docs.document_version
       SET virus_scan_status = ${verdict}, virus_scanned_at = now(), sha256_hash = ${digest}
     WHERE version_id = ${v.version_id}
  `);

  if (verdict === 'infected') {
    await dbAdmin.execute(sql`
      INSERT INTO core.notification (tenant_id, channel, subject, body, payload)
      SELECT d.tenant_id, 'email', 'SECURITY: infected upload quarantined',
             'Document ' || d.doc_number || ' failed malware scanning and is blocked.',
             jsonb_build_object('document_id', d.document_id)
        FROM docs.document d WHERE d.document_id = ${d.documentId}
    `);
    return { verdict, quarantined: true };
  }

  // Evidence integrity: bind the hash to the evidence record
  await dbAdmin.execute(sql`
    UPDATE frame.evidence SET sha256_hash = ${digest}
     WHERE document_id = ${d.documentId} AND sha256_hash IS NULL
  `);

  await enqueue('document.embed', { documentId: d.documentId, version: d.version });
  return { verdict, sha256: digest };
}

export async function embedDocument(d: JobMap['document.embed']) {
  // Extract → chunk → embed → kb.chunk. Text extraction by mime type;
  // pdf-parse / mammoth / plain read, then chunk at ~800 tokens with 100 overlap.
  // Left as an integration point — the vector column and HNSW index already exist.
  return { documentId: d.documentId, status: 'queued_for_extraction' };
