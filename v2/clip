// packages/storage/src/documents.ts
import { S3Client, PutObjectCommand, GetObjectCommand, HeadObjectCommand } from '@aws-sdk/client-s3';
import { getSignedUrl } from '@aws-sdk/s3-request-presigner';
import { randomUUID } from 'node:crypto';

const s3 = new S3Client({
  endpoint: process.env.S3_ENDPOINT,
  region: process.env.S3_REGION ?? 'us-east-1',
  forcePathStyle: true,
  credentials: {
    accessKeyId: process.env.S3_ACCESS_KEY!,
    secretAccessKey: process.env.S3_SECRET_KEY!,
  },
});

const BUCKET = process.env.S3_BUCKET ?? 'intune-documents';

/** Key layout keeps tenant isolation visible at the object-store level. */
export function buildKey(p: {
  tenantId: string; clientId?: string; documentId: string; version: number; filename: string;
}) {
  const safe = p.filename.replace(/[^\w.\-]/g, '_').slice(0, 120);
  const scope = p.clientId ? `clients/${p.clientId}` : 'internal';
  return `${p.tenantId}/${scope}/${p.documentId}/v${p.version}/${safe}`;
}

/** Direct-to-storage upload. Bytes never transit the Next.js process. */
export async function presignUpload(key: string, contentType: string, maxBytes = 200 * 1024 ** 2) {
  return getSignedUrl(s3, new PutObjectCommand({
    Bucket: BUCKET,
    Key: key,
    ContentType: contentType,
    ServerSideEncryption: 'AES256',
    Metadata: { uploadid: randomUUID() },
  }), { expiresIn: 900, signableHeaders: new Set(['content-type', 'content-length']) });
}

/** Short TTL — every download is logged server-side before the URL is minted. */
export async function presignDownload(key: string, filename: string, ttl = 300) {
  return getSignedUrl(s3, new GetObjectCommand({
    Bucket: BUCKET,
    Key: key,
    ResponseContentDisposition: `attachment; filename="${encodeURIComponent(filename)}"`,
  }), { expiresIn: ttl });
}

export async function objectMeta(key: string) {
  const r = await s3.send(new HeadObjectCommand({ Bucket: BUCKET, Key: key }));
  return { size: r.ContentLength, etag: r.ETag, contentType: r.ContentType };
}
