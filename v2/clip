```typescript
// packages/crypto/src/field.ts
import { createCipheriv, createDecipheriv, randomBytes, createHash } from 'node:crypto';

/**
 * Envelope encryption for PII at rest (EIN, SSN, account numbers).
 * Stored as: [1B version][12B IV][16B tag][ciphertext] → BYTEA.
 * DEK held in env/KMS; the DB never sees the key material.
 */
const VERSION = 0x01;

function dek(): Buffer {
  const k = process.env.FIELD_ENCRYPTION_KEY;
  if (!k) throw new Error('FIELD_ENCRYPTION_KEY not set');
  const buf = Buffer.from(k, 'base64');
  if (buf.length !== 32) throw new Error('FIELD_ENCRYPTION_KEY must be 32 bytes base64');
  return buf;
}

export async function encryptField(plaintext: string, aad?: string): Promise<Buffer> {
  const iv = randomBytes(12);
  const cipher = createCipheriv('aes-256-gcm', dek(), iv);
  if (aad) cipher.setAAD(Buffer.from(aad, 'utf8'));
  const ct = Buffer.concat([cipher.update(plaintext, 'utf8'), cipher.final()]);
  return Buffer.concat([Buffer.from([VERSION]), iv, cipher.getAuthTag(), ct]);
}

export async function decryptField(blob: Buffer, aad?: string): Promise<string> {
  if (blob[0] !== VERSION) throw new Error(`unsupported field cipher version ${blob[0]}`);
  const iv = blob.subarray(1, 13);
  const tag = blob.subarray(13, 29);
  const ct = blob.subarray(29);
  const d = createDecipheriv('aes-256-gcm', dek(), iv);
  d.setAuthTag(tag);
  if (aad) d.setAAD(Buffer.from(aad, 'utf8'));
  return Buffer.concat([d.update(ct), d.final()]).toString('utf8');
}

/** Deterministic blind index — enables equality search on encrypted columns. */
export function blindIndex(value: string): string {
  const pepper = process.env.BLIND_INDEX_PEPPER;
  if (!pepper) throw new Error('BLIND_INDEX_PEPPER not set');
  return createHash('sha256')
    .update(pepper).update('\x00').update(value.trim().toLowerCase())
    .digest('hex');
}

export const sha256 = (b: Buffer | string) =>
  createHash('sha256').update(b).digest('hex');
