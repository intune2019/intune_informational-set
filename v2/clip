  if (c.req.path.endsWith('/health')) return next();

  const raw = c.req.header('x-api-key');
  if (!raw) return c.json({ error: 'missing_api_key' }, 401);

  const hash = createHash('sha256').update(raw).digest('hex');
  const key = await withAnon(async (tx) => {
    const [k] = await tx.execute(sql`
      SELECT api_key_id, user_id, tenant_id, scopes, expires_at, revoked_at
        FROM core.api_key WHERE key_hash = ${hash} LIMIT 1
    `).then((r) => r.rows as any[]);
    return k;
  });

  if (!key || key.revoked_at || (key.expires_at && new Date(key.expires_at) < new Date())) {
    return c.json({ error: 'invalid_api_key' }, 401);
  }

  c.set('actorId', key.user_id);
  c.set('tenantId', key.tenant_id);
  c.set('scopes', key.scopes ?? []);

  // Fire-and-forget last-use stamp
  withAnon((tx) => tx.execute(sql`
    UPDATE core.api_key SET last_used_at = now(), use_count = use_count + 1
     WHERE api_key_id = ${key.api_key_id}`)).catch(() => {});

  await next();
});

