## SECTION 4: AUTH

Custom sessions rather than NextAuth — you need MFA enforcement, SoD checks at grant time, and Entra ID federation with tight control over the token exchange. NextAuth fights you on all three.

```typescript
// packages/auth/src/session.ts
import { randomBytes, createHash, timingSafeEqual } from 'node:crypto';
import { cookies } from 'next/headers';
import { redis } from './redis.js';

const SESSION_COOKIE = '__Host-intune_sid';
const SESSION_TTL = 60 * 60 * 8;        // 8h absolute
const IDLE_TTL = 60 * 30;               // 30m idle

export interface Session {
  sid: string;
  userId: string;
  tenantId: string;
  isStaff: boolean;
  mfaVerified: boolean;
  permissions: string[];
  roles: string[];
  visibleClientIds: string[];
  issuedAt: number;
  absoluteExpiry: number;
  ip: string;
  ua: string;
}

const hashSid = (raw: string) => createHash('sha256').update(raw).digest('hex');

export async function createSession(
  data: Omit<Session, 'sid' | 'issuedAt' | 'absoluteExpiry'>,
): Promise<string> {
  const raw = randomBytes(32).toString('base64url');
  const sid = hashSid(raw);
  const now = Math.floor(Date.now() / 1000);

  const session: Session = { ...data, sid, issuedAt: now, absoluteExpiry: now + SESSION_TTL };

  await redis.setex(`sess:${sid}`, IDLE_TTL, JSON.stringify(session));
  await redis.sadd(`usess:${data.userId}`, sid);          // for global revoke
  await redis.expire(`usess:${data.userId}`, SESSION_TTL);

  (await cookies()).set(SESSION_COOKIE, raw, {
    httpOnly: true,
    secure: true,
    sameSite: 'lax',
    path: '/',
    maxAge: SESSION_TTL,
  });
  return sid;
}

export async function getSession(): Promise<Session | null> {
  const raw = (await cookies()).get(SESSION_COOKIE)?.value;
  if (!raw) return null;

  const sid = hashSid(raw);
  const json = await redis.get(`sess:${sid}`);
  if (!json) return null;

  const session = JSON.parse(json) as Session;

  // Constant-time sid compare guards against cache-probing oracles
  const a = Buffer.from(session.sid);
  const b = Buffer.from(sid);
  if (a.length !== b.length || !timingSafeEqual(a, b)) return null;

  if (Math.floor(Date.now() / 1000) > session.absoluteExpiry) {
    await destroySession(sid, session.userId);
    return null;
  }

  await redis.expire(`sess:${sid}`, IDLE_TTL);            // sliding idle window
  return session;
}

export async function destroySession(sid: string, userId: string) {
  await redis.del(`sess:${sid}`);
  await redis.srem(`usess:${userId}`, sid);
  (await cookies()).delete(SESSION_COOKIE);
}

/** Role revoked, password changed, account disabled → kill everything. */
export async function revokeAllUserSessions(userId: string) {
  const sids = await redis.smembers(`usess:${userId}`);
  if (sids.length) await redis.del(...sids.map((s) => `sess:${s}`));
  await redis.del(`usess:${userId}`);
}
```

```typescript
// packages/auth/src/authenticate.ts
import { randomBytes, timingSafeEqual } from 'node:crypto';
import argon2 from 'argon2';
import { withAnon, withActor, schema } from '@intune/db';
import { eq, and, or, isNull, gt, sql } from 'drizzle-orm';
import { createSession } from './session.js';
import { redis } from './redis.js';

const ARGON_OPTS = {
  type: argon2.argon2id,
  memoryCost: 65536,
  timeCost: 3,
  parallelism: 4,
} as const;

export const hashPassword = (pw: string) => argon2.hash(pw, ARGON_OPTS);

/** Loads perms + roles + visible clients in one round trip. */
async function loadPrincipal(userId: string, tenantId: string) {
  return withActor({ actorId: userId, tenantId }, async (tx) => {
    const rows = await tx.execute(sql`
      SELECT
        (SELECT coalesce(array_agg(DISTINCT p.perm_code), '{}')
           FROM core.user_role ur
           JOIN core.role_permission rp ON rp.role_id = ur.role_id
           JOIN core.permission p ON p.permission_id = rp.permission_id
          WHERE ur.user_id = ${userId}
            AND (ur.expires_at IS NULL OR ur.expires_at > now())) AS permissions,
        (SELECT coalesce(array_agg(DISTINCT r.role_code), '{}')
           FROM core.user_role ur
           JOIN core.role r ON r.role_id = ur.role_id
          WHERE ur.user_id = ${userId}
            AND (ur.expires_at IS NULL OR ur.expires_at > now())) AS roles,
        (SELECT coalesce(array_agg(DISTINCT c.client_id), '{}')
           FROM crm.contact c
          WHERE c.portal_user_id = ${userId}
            AND c.record_status = 'active') AS visible_clients
    `);
    const r = rows.rows[0] as any;
    return {
      permissions: (r.permissions ?? []) as string[],
      roles: (r.roles ?? []) as string[],
      visibleClientIds: (r.visible_clients ?? []) as string[],
    };
  });
}

export async function authenticate(
  email: string,
  password: string,
  ip: string,
  ua: string,
): Promise
  | { ok: true; requiresMfa: boolean; userId: string }
  | { ok: false; reason: 'invalid' | 'locked' | 'disabled' }
> {
  const lockKey = `lock:${email.toLowerCase()}`;
  const attempts = Number((await redis.get(lockKey)) ?? 0);
  if (attempts >= 5) return { ok: false, reason: 'locked' };

  const user = await withAnon(async (tx) => {
    const [u] = await tx.execute(sql`
      SELECT u.user_id, u.tenant_id, u.is_staff, u.mfa_enrolled,
             u.record_status, cr.password_hash
        FROM core.app_user u
        LEFT JOIN core.user_credential cr ON cr.user_id = u.user_id
       WHERE lower(u.email) = lower(${email})
       LIMIT 1
    `).then((r) => r.rows as any[]);
    return u;
  });

  // Dummy verify on miss — equalises timing, prevents user enumeration
  if (!user) {
    await argon2.verify(
      '$argon2id$v=19$m=65536,t=3,p=4$AAAAAAAAAAAAAAAAAAAAAA$AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA',
      password,
    ).catch(() => {});
    await redis.incr(lockKey);
    await redis.expire(lockKey, 900);
    return { ok: false, reason: 'invalid' };
  }

  if (user.record_status !== 'active') return { ok: false, reason: 'disabled' };

  const valid = await argon2.verify(user.password_hash, password).catch(() => false);
  if (!valid) {
    await redis.incr(lockKey);
    await redis.expire(lockKey, 900);
    return { ok: false, reason: 'invalid' };
  }

  await redis.del(lockKey);

  // Staff MFA is mandatory — no bypass path exists
  if (user.is_staff && !user.mfa_enrolled) {
    return { ok: true, requiresMfa: true, userId: user.user_id };
  }

  const principal = await loadPrincipal(user.user_id, user.tenant_id);
  await createSession({
    userId: user.user_id,
    tenantId: user.tenant_id,
    isStaff: user.is_staff,
    mfaVerified: !user.mfa_enrolled,
    ip, ua,
    ...principal,
  });

  return { ok: true, requiresMfa: user.mfa_enrolled, userId: user.user_id };
}
