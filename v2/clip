// packages/jobs/src/queue.ts
import { Queue, type JobsOptions } from 'bullmq';
import IORedis from 'ioredis';

export const connection = new IORedis(process.env.REDIS_URL!, {
  maxRetriesPerRequest: null,
  enableReadyCheck: false,
});

export interface JobMap {
  'notification.send': { tenantId: string; notificationId?: string; template: string; payload: Record<string, unknown> };
  'document.scan': { documentId: string; version: number };
  'document.embed': { documentId: string; version: number };
  'screening.run': { screeningId: string; provider: string; searchTerm: string; listType: string };
  'report.render': { assessmentId: string; format: 'pdf' | 'docx'; requestedBy: string };
  'certificate.sync': { certificateId?: string };
  'kb.reindex': { articleId: string };
}

export const queues = {
  default: new Queue('default', { connection }),
  documents: new Queue('documents', { connection }),
  screening: new Queue('screening', { connection }),
  reports: new Queue('reports', { connection }),
} as const;

const routing: Record<keyof JobMap, keyof typeof queues> = {
  'notification.send': 'default',
  'document.scan': 'documents',
  'document.embed': 'documents',
  'screening.run': 'screening',
  'report.render': 'reports',
  'certificate.sync': 'default',
  'kb.reindex': 'documents',
};

export async function enqueue<K extends keyof JobMap>(
  name: K, data: JobMap[K], opts?: JobsOptions,
) {
  return queues[routing[name]].add(name, data, {
    attempts: 5,
    backoff: { type: 'exponential', delay: 5_000 },
    removeOnComplete: { age: 86_400, count: 1_000 },
    removeOnFail: { age: 604_800 },
    ...opts,
  });
}
