  targetUserId: string,
  newRoleId: string,
): Promise<SodViolation[]> {
  return withActor(ctx, async (tx) => {
    const r = await tx.execute(sql`
      SELECT ra.role_code AS role_a, rb.role_code AS role_b,
             sc.severity::text AS severity, sc.rationale
        FROM core.sod_conflict sc
        JOIN core.role ra ON ra.role_id = sc.role_a_id
        JOIN core.role rb ON rb.role_id = sc.role_b_id
       WHERE (sc.role_a_id = ${newRoleId} AND sc.role_b_id IN (
                SELECT role_id FROM core.user_role
                 WHERE user_id = ${targetUserId}
                   AND (expires_at IS NULL OR expires_at > now())))
          OR (sc.role_b_id = ${newRoleId} AND sc.role_a_id IN (
                SELECT role_id FROM core.user_role
                 WHERE user_id = ${targetUserId}
                   AND (expires_at IS NULL OR expires_at > now())))
    `);
    return r.rows as unknown as SodViolation[];
  });
}
