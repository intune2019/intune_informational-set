## SECTION 6: SERVER ACTION LAYER

Every mutation flows through one gate: authenticated → MFA-verified → CASL-checked → RLS-scoped transaction → audited by trigger. There is no second path.

```typescript
// apps/web/src/lib/safe-action.ts
import { createSafeActionClient, DEFAULT_SERVER_ERROR_MESSAGE } from 'next-safe-action';
import { z } from 'zod';
import { headers } from 'next/headers';
import { getSession } from '@intune/auth';
import { defineAbility } from '@intune/policy';
import { withActor, type Db } from '@intune/db';
import { logger } from '@intune/observability';
import { randomUUID } from 'node:crypto';

export class ForbiddenError extends Error {}
export class ValidationError extends Error {}

export const actionClient = createSafeActionClient({
  defineMetadataSchema: () =>
    z.object({
      name: z.string(),
      requiresMfa: z.boolean().default(true),
    }),
  handleServerError(e, { metadata }) {
    if (e instanceof ForbiddenError) return e.message;
    if (e instanceof ValidationError) return e.message;
    // DB CHECK/trigger violations surface as business rules — the DB IS the rulebook
    const msg = (e as any)?.message ?? '';
    if (msg.includes('ICAEF violation') || msg.includes('TrustFabric:')) return msg;
    if ((e as any)?.code === '23505') return 'A record with that identifier already exists.';
    if ((e as any)?.code === '23514') return 'That change violates a business rule.';
    if ((e as any)?.code === '42501') return 'You do not have access to that record.';
    logger.error({ err: e, action: metadata?.name }, 'unhandled server action error');
    return DEFAULT_SERVER_ERROR_MESSAGE;
  },
});

/** Authenticated + MFA-enforced + ability-bound + transaction-scoped. */
export const authAction = actionClient.use(async ({ next, metadata }) => {
  const session = await getSession();
  if (!session) throw new ForbiddenError('Not authenticated.');
  if (metadata.requiresMfa && session.isStaff && !session.mfaVerified) {
    throw new ForbiddenError('MFA verification required.');
  }

  const h = await headers();
  const requestId = h.get('x-request-id') ?? randomUUID();
  const ability = defineAbility(session);

  const ctx = {
    actorId: session.userId,
    tenantId: session.tenantId,
    requestId,
    clientIp: h.get('x-forwarded-for')?.split(',')[0]?.trim(),
  };

  return next({
    ctx: {
      session,
      ability,
      requestId,
      /** All DB work goes through here. Never import a raw pool in a route. */
      db: <T>(fn: (tx: Db) => Promise<T>) => withActor(ctx, fn),
    },
  });
});

export const staffAction = authAction.use(async ({ next, ctx }) => {
  if (!ctx.session.isStaff) throw new ForbiddenError('Staff access required.');
  return next({ ctx });
});
