## SECTION 3: THE ENFORCEMENT LAYER

This is what makes it an audit rather than a form.

```sql
-- ============================================================
-- 32_ENGINE_RULES
-- ============================================================

-- ---------- Evidence before conclusion (ICAEF, enforced) ----------
CREATE OR REPLACE FUNCTION inst.fn_require_evidence()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_min frame.evidence_tier; v_kind inst.section_kind; v_code TEXT; v_count INT;
BEGIN
  IF NEW.rating IS NULL OR (OLD.rating IS NOT DISTINCT FROM NEW.rating) THEN
    RETURN NEW;
  END IF;

  SELECT s.min_evidence_tier, s.section_kind, s.section_code
    INTO v_min, v_kind, v_code
    FROM inst.section s WHERE s.section_id = NEW.section_id;

  -- Scoping and document-request sections don't carry conclusions
  IF v_kind IN ('scoping','document_request') THEN RETURN NEW; END IF;

  SELECT count(*) INTO v_count
    FROM inst.evidence e
   WHERE e.section_response_id = NEW.section_response_id
     AND e.is_sufficient IS TRUE
     AND e.tier <= v_min;

  IF v_count = 0 THEN
    RAISE EXCEPTION
      'ICAEF: section % cannot be rated without at least one sufficient % (or stronger) evidence item.',
      v_code, v_min;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_inst_require_evidence
  BEFORE UPDATE ON inst.section_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_require_evidence();

-- ---------- Mandatory documents must be resolved ----------
CREATE OR REPLACE FUNCTION inst.fn_require_documents()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_open INT; v_code TEXT;
BEGIN
  IF NEW.state NOT IN ('ready_for_review','complete') THEN RETURN NEW; END IF;

  SELECT s.section_code INTO v_code FROM inst.section s WHERE s.section_id = NEW.section_id;

  SELECT count(*) INTO v_open
    FROM inst.document_requirement dr
    LEFT JOIN inst.document_collection dc
      ON dc.requirement_id = dr.requirement_id
     AND dc.administration_id = NEW.administration_id
   WHERE dr.section_id = NEW.section_id
     AND dr.is_mandatory
     AND dr.record_status = 'active'
     AND COALESCE(dc.status, 'requested') NOT IN ('accepted','waived','not_available');

  IF v_open > 0 THEN
    RAISE EXCEPTION
      'Section % has % mandatory document requirement(s) unresolved. Accept, waive, or mark unavailable first.',
      v_code, v_open;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_inst_require_docs
  BEFORE UPDATE ON inst.section_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_require_documents();

-- ---------- Required inputs answered ----------
CREATE OR REPLACE FUNCTION inst.fn_require_inputs()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_missing TEXT[]; v_code TEXT;
BEGIN
  IF NEW.state NOT IN ('ready_for_review','complete') THEN RETURN NEW; END IF;

  SELECT s.section_code INTO v_code FROM inst.section s WHERE s.section_id = NEW.section_id;

  SELECT array_agg(i.input_code) INTO v_missing
    FROM inst.input i
    LEFT JOIN inst.input_response ir
      ON ir.input_id = i.input_id AND ir.section_response_id = NEW.section_response_id
   WHERE i.section_id = NEW.section_id
     AND i.is_required
     AND i.record_status = 'active'
     AND (ir.input_response_id IS NULL OR ir.value_json IS NULL
          OR ir.value_json->>'v' IS NULL OR ir.value_json->>'v' = '');

  IF v_missing IS NOT NULL THEN
    RAISE EXCEPTION 'Section % is missing required inputs: %', v_code, array_to_string(v_missing, ', ');
  END IF;

  IF NEW.state = 'ready_for_review' THEN
    IF EXISTS (SELECT 1 FROM inst.section s
                WHERE s.section_id = NEW.section_id
                  AND s.requires_narrative AND coalesce(trim(NEW.narrative),'') = '') THEN
      RAISE EXCEPTION 'Section % requires a narrative before review.', v_code;
    END IF;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_inst_require_inputs
  BEFORE UPDATE ON inst.section_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_require_inputs();

-- ---------- Risk scoring ----------
CREATE OR REPLACE FUNCTION inst.fn_score_input()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_rule JSONB; v_weight NUMERIC; v_val TEXT; v_score NUMERIC := 0;
BEGIN
  SELECT i.risk_rule, i.risk_weight INTO v_rule, v_weight
    FROM inst.input i WHERE i.input_id = NEW.input_id;

  IF v_rule IS NULL OR v_weight = 0 THEN
    NEW.computed_risk := 0; RETURN NEW;
  END IF;

  v_val := NEW.value_json ->> 'v';

  CASE v_rule ->> 'type'
    WHEN 'map' THEN
      v_score := COALESCE((v_rule -> 'map' ->> v_val)::numeric, 0);
    WHEN 'boolean' THEN
      v_score := CASE WHEN v_val = 'true'
                      THEN COALESCE((v_rule ->> 'score_if_true')::numeric, 0)
                      ELSE COALESCE((v_rule ->> 'score_if_false')::numeric, 0) END;
    WHEN 'threshold' THEN
      v_score := CASE
        WHEN (v_rule ? 'gt') AND v_val::numeric >  (v_rule ->> 'gt')::numeric
          THEN (v_rule ->> 'score')::numeric
        WHEN (v_rule ? 'lt') AND v_val::numeric <  (v_rule ->> 'lt')::numeric
          THEN (v_rule ->> 'score')::numeric
        ELSE 0 END;
    WHEN 'scale_inverse' THEN
      v_score := 5 - COALESCE(v_val::numeric, 5);
    ELSE v_score := 0;
  END CASE;

  NEW.computed_risk := v_score * v_weight;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_score_input
  BEFORE INSERT OR UPDATE ON inst.input_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_score_input();

-- ---------- Roll section score + auto-generate findings ----------
CREATE OR REPLACE FUNCTION inst.fn_roll_section_score()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_total NUMERIC; v_sr UUID; v_trigger JSONB; v_tmpl TEXT; v_val TEXT;
        v_admin UUID; v_code TEXT; v_fire BOOLEAN := false;
BEGIN
  v_sr := NEW.section_response_id;

  SELECT COALESCE(sum(computed_risk), 0) INTO v_total
    FROM inst.input_response WHERE section_response_id = v_sr AND record_status = 'active';

  UPDATE inst.section_response SET section_risk_score = v_total WHERE section_response_id = v_sr;

  -- Auto-finding
  SELECT i.triggers_finding_when, i.finding_template, i.input_code
    INTO v_trigger, v_tmpl, v_code
    FROM inst.input i WHERE i.input_id = NEW.input_id;

  IF v_trigger IS NOT NULL AND v_tmpl IS NOT NULL THEN
    v_val := NEW.value_json ->> 'v';
    v_fire := CASE v_trigger ->> 'op'
      WHEN 'eq'  THEN v_val = (v_trigger ->> 'value')
      WHEN 'neq' THEN v_val <> (v_trigger ->> 'value')
      WHEN 'lt'  THEN v_val::numeric <  (v_trigger ->> 'value')::numeric
      WHEN 'gt'  THEN v_val::numeric >  (v_trigger ->> 'value')::numeric
      WHEN 'in'  THEN v_trigger -> 'value' ? v_val
      ELSE false END;

    IF v_fire THEN
      SELECT sr.administration_id INTO v_admin
        FROM inst.section_response sr WHERE sr.section_response_id = v_sr;

      INSERT INTO inst.finding (
        administration_id, section_response_id, finding_number, title,
        condition, criteria, recommendation, severity, rating, auto_generated, status)
      SELECT v_admin, v_sr,
             'F-' || lpad((SELECT count(*)+1 FROM inst.finding
                            WHERE administration_id = v_admin)::text, 3, '0'),
             v_tmpl,
             'Auto-detected from response to ' || v_code || ': ' || COALESCE(v_val,'(blank)'),
             COALESCE(s.review_criteria, 'See section criteria'),
             'Pending assessor recommendation.',
             'moderate', 'deficient', true, 'draft'
        FROM inst.section s
        JOIN inst.section_response sr ON sr.section_id = s.section_id
       WHERE sr.section_response_id = v_sr
      ON CONFLICT DO NOTHING;
    END IF;
  END IF;
  RETURN NULL;
END $$;

CREATE TRIGGER trg_roll_section_score
  AFTER INSERT OR UPDATE ON inst.input_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_roll_section_score();

-- ---------- Administration rollup ----------
CREATE OR REPLACE FUNCTION inst.fn_roll_administration(p_admin UUID)
RETURNS void LANGUAGE plpgsql AS $$
DECLARE v_pct NUMERIC; v_risk NUMERIC; v_mat NUMERIC; v_rating frame.exam_rating;
BEGIN
  SELECT
    round(100.0 * count(*) FILTER (WHERE sr.state IN ('complete','not_applicable'))
          / NULLIF(count(*), 0), 2),
    COALESCE(sum(sr.section_risk_score * s.weight), 0),
    round(sum(sr.maturity_level * s.weight) FILTER (WHERE sr.maturity_level IS NOT NULL)
          / NULLIF(sum(s.weight) FILTER (WHERE sr.maturity_level IS NOT NULL), 0), 2)
  INTO v_pct, v_risk, v_mat
  FROM inst.section_response sr
  JOIN inst.section s ON s.section_id = sr.section_id
  WHERE sr.administration_id = p_admin AND sr.record_status = 'active';

  -- Worst key-section rating drives the overall
  SELECT max(sr.rating::text)::frame.exam_rating INTO v_rating
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.administration_id = p_admin AND s.is_key_section AND sr.rating IS NOT NULL;

  UPDATE inst.administration
     SET completion_pct = COALESCE(v_pct, 0),
         risk_score = v_risk,
         maturity_score = v_mat,
         overall_rating = COALESCE(v_rating, overall_rating),
         updated_at = now()
   WHERE administration_id = p_admin;
END $$;

-- ---------- Materialize an instrument onto an engagement ----------
CREATE OR REPLACE FUNCTION inst.fn_instantiate(
  p_engagement UUID, p_instrument UUID, p_party UUID,
  p_period_start DATE, p_period_end DATE, p_lead UUID)
RETURNS UUID LANGUAGE plpgsql AS $$
DECLARE v_admin UUID; v_tenant UUID; v_code TEXT;
BEGIN
  IF NOT EXISTS (SELECT 1 FROM inst.instrument
                  WHERE instrument_id = p_instrument AND is_published) THEN
    RAISE EXCEPTION 'Instrument is not published; cannot be administered.';
  END IF;

  SELECT tenant_id INTO v_tenant FROM engage.engagement WHERE engagement_id = p_engagement;
  SELECT instrument_code INTO v_code FROM inst.instrument WHERE instrument_id = p_instrument;

  INSERT INTO inst.administration (
    tenant_id, engagement_id, instrument_id, party_id, admin_number,
    period_start, period_end, lead_assessor, status)
  VALUES (v_tenant, p_engagement, p_instrument, p_party,
    v_code || '-' || to_char(now(),'YYYY') || '-' ||
      lpad(nextval('inst.seq_admin')::text, 4, '0'),
    p_period_start, p_period_end, p_lead, 'planning')
  RETURNING administration_id INTO v_admin;

  -- Every section gets a response shell
  INSERT INTO inst.section_response (administration_id, section_id, state)
  SELECT v_admin, s.section_id, 'not_started'
    FROM inst.section s
   WHERE s.instrument_id = p_instrument AND s.record_status = 'active';

  -- Every mandatory doc requirement becomes an open request
  INSERT INTO inst.document_collection (
    administration_id, requirement_id, section_response_id,
    requested_from, due_date, status)
  SELECT v_admin, dr.requirement_id, sr.section_response_id, p_party,
         CURRENT_DATE + COALESCE(dr.lead_time_days, 5), 'requested'
    FROM inst.document_requirement dr
    JOIN inst.section s ON s.section_id = dr.section_id
    JOIN inst.section_response sr
      ON sr.section_id = s.section_id AND sr.administration_id = v_admin
   WHERE s.instrument_id = p_instrument AND dr.record_status = 'active';

  RETURN v_admin;
END $$;

CREATE SEQUENCE IF NOT EXISTS inst.seq_admin;
