Understood — the engine, built for real instruments. Not answer matrices. Each section knows what documents it needs, what the assessor reviews them against, where notes go, what gets uploaded, and what comes out.

Let me build the engine now. TRM™ as the worked instantiation, because treasury is where your CTP background will catch my errors fastest.

## SECTION 1: THE INSTRUMENT MODEL

The distinction that makes this real rather than a questionnaire: **a section is a unit of fieldwork.** It has a purpose, a document manifest, review criteria, an evidence bar, a notes surface, and an outcome. A question is one input inside it — not the point.

```sql
-- ============================================================
-- 30_INSTRUMENT :: THE FRAMEWORK ENGINE
-- ============================================================

CREATE SCHEMA IF NOT EXISTS inst;

CREATE TYPE inst.input_kind AS ENUM (
  'short_text','long_text','number','currency','percent','date','date_range',
  'single_select','multi_select','boolean','yes_no_na','scale_1_5',
  'party_ref','user_ref','document_ref','table_grid','signature','attestation',
  'computed'
);

CREATE TYPE inst.section_kind AS ENUM (
  'scoping',            -- defines what's in scope
  'document_request',   -- PBC list
  'inquiry',            -- interview / questionnaire
  'inspection',         -- assessor reviews documents against criteria
  'observation',        -- assessor watches a process
  'reperformance',      -- assessor re-executes a control
  'analytical',         -- data analysis
  'attestation',        -- client certifies
  'conclusion'          -- assessor rates the domain
);

CREATE TYPE inst.completion_state AS ENUM (
  'not_started','in_progress','client_pending','ready_for_review',
  'reviewed','reopened','complete','not_applicable'
);

-- ============================================================
-- INSTRUMENT — versioned, published, immutable once used
-- ============================================================
CREATE TABLE inst.instrument (
  instrument_id   UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  framework_id    UUID NOT NULL REFERENCES frame.framework(framework_id),
  instrument_code TEXT NOT NULL,
  version         INT NOT NULL DEFAULT 1,
  title           TEXT NOT NULL,
  purpose         TEXT NOT NULL,
  core_question   TEXT,
  scope_statement TEXT,
  intended_use    TEXT,
  estimated_hours NUMERIC(6,2),
  estimated_days  INT,

  -- Report specification
  report_template_code TEXT,
  deliverables    TEXT[],          -- ['Treasury Control Register','Liquidity Risk Review']

  is_published    BOOLEAN NOT NULL DEFAULT false,
  published_at    TIMESTAMPTZ,
  published_by    UUID REFERENCES core.app_user(user_id),
  superseded_by   UUID REFERENCES inst.instrument(instrument_id),

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'draft',
  CONSTRAINT uq_instrument_ver UNIQUE (instrument_code, version)
);

-- Published instruments are frozen. Change = new version.
CREATE OR REPLACE FUNCTION inst.fn_freeze_published()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  IF OLD.is_published AND NEW.is_published
     AND (OLD.instrument_code, OLD.version) IS DISTINCT FROM (NEW.instrument_code, NEW.version) THEN
    RAISE EXCEPTION 'Instrument %v% is published and cannot be altered. Create a new version.',
      OLD.instrument_code, OLD.version;
  END IF;
  RETURN NEW;
END $$;
CREATE TRIGGER trg_freeze_instrument BEFORE UPDATE ON inst.instrument
  FOR EACH ROW EXECUTE FUNCTION inst.fn_freeze_published();

-- ============================================================
-- SECTION — a unit of fieldwork, not a page of a form
-- ============================================================
CREATE TABLE inst.section (
  section_id      UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  instrument_id   UUID NOT NULL REFERENCES inst.instrument(instrument_id) ON DELETE CASCADE,
  domain_id       UUID REFERENCES frame.domain(domain_id),
  parent_section_id UUID REFERENCES inst.section(section_id) ON DELETE CASCADE,

  section_code    TEXT NOT NULL,        -- 'TRM.TG.01'
  title           TEXT NOT NULL,
  section_kind    inst.section_kind NOT NULL,
  sort_order      INT NOT NULL DEFAULT 0,

  -- WHAT THIS SECTION IS FOR
  purpose         TEXT NOT NULL,
  what_we_assess  TEXT NOT NULL,
  why_it_matters  TEXT,

  -- WHAT THE ASSESSOR REVIEWS AGAINST
  review_criteria TEXT NOT NULL,        -- the "according to this"
  criteria_refs   TEXT[],               -- ['FFIEC BSA/AML - Internal Controls','NIST CSF GV.RM-01']
  red_flags       TEXT[],               -- what a deficiency looks like
  good_practice   TEXT,                 -- what "effective" looks like

  -- EVIDENCE BAR
  min_evidence_tier frame.evidence_tier NOT NULL DEFAULT 'tier_ii',
  evidence_guidance TEXT,
  sample_guidance   TEXT,
  min_sample_size   INT,

  -- WHO
  performed_by_role TEXT,               -- 'ASSESSOR','TREASURY_ANALYST'
  client_role_required TEXT,            -- 'Treasurer','CFO','Controller'

  -- NOTES SURFACE
  requires_narrative BOOLEAN NOT NULL DEFAULT true,
  narrative_prompt   TEXT,
  requires_conclusion BOOLEAN NOT NULL DEFAULT false,

  -- SCORING
  weight          NUMERIC(5,2) NOT NULL DEFAULT 1.0,
  is_key_section  BOOLEAN NOT NULL DEFAULT false,
  na_permitted    BOOLEAN NOT NULL DEFAULT true,
  na_requires_rationale BOOLEAN NOT NULL DEFAULT true,

  -- CONDITIONAL DISPLAY
  show_when       JSONB,                -- {"field":"TRM.TG.01.Q3","op":"eq","value":true}

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_section_code UNIQUE (instrument_id, section_code)
);
CREATE INDEX ix_section_instr ON inst.section (instrument_id, sort_order);

COMMENT ON TABLE inst.section IS
  'A unit of fieldwork. Carries purpose, review criteria, document manifest,
   evidence bar, notes surface, and outcome. Questions are inputs inside it.';

-- ============================================================
-- DOCUMENT MANIFEST — "I need this and that"
-- ============================================================
CREATE TABLE inst.document_requirement (
  requirement_id  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  section_id      UUID NOT NULL REFERENCES inst.section(section_id) ON DELETE CASCADE,
  req_code        TEXT NOT NULL,        -- 'TRM.TG.01.D1'
  sort_order      INT NOT NULL DEFAULT 0,

  document_name   TEXT NOT NULL,        -- 'Treasury Policy'
  description     TEXT NOT NULL,        -- what specifically
  doc_type        TEXT,                 -- maps to docs.document.doc_type
  format_expected TEXT,                 -- 'PDF, signed and dated'
  period_covered  TEXT,                 -- 'Current effective version + prior 2 years'

  is_mandatory    BOOLEAN NOT NULL DEFAULT true,
  alternatives_accepted TEXT,           -- 'If no formal policy, board minutes evidencing...'

  -- WHAT THE ASSESSOR CHECKS ON RECEIPT
  review_checklist TEXT[] NOT NULL,     -- ['Is it board-approved?','Is it within review cycle?']
  acceptance_criteria TEXT,
  common_deficiencies TEXT[],

  evidence_tier   frame.evidence_tier NOT NULL DEFAULT 'tier_ii',
  requested_from_role TEXT,             -- 'Treasurer'
  lead_time_days  INT DEFAULT 5,

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_docreq UNIQUE (section_id, req_code)
);

-- ============================================================
-- INPUT — the actual fields
-- ============================================================
CREATE TABLE inst.input (
  input_id        UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  section_id      UUID NOT NULL REFERENCES inst.section(section_id) ON DELETE CASCADE,
  input_code      TEXT NOT NULL,        -- 'TRM.TG.01.Q1'
  sort_order      INT NOT NULL DEFAULT 0,

  label           TEXT NOT NULL,
  help_text       TEXT,
  assessor_guidance TEXT,               -- what the assessor should be probing for
  input_kind      inst.input_kind NOT NULL,

  is_required     BOOLEAN NOT NULL DEFAULT true,
  answered_by     TEXT NOT NULL DEFAULT 'assessor'
                  CHECK (answered_by IN ('assessor','client','system')),

  -- Constraints
  options         JSONB,                -- [{"value":"yes","label":"Yes","risk_score":0}]
  validation      JSONB,                -- {"min":0,"max":100,"pattern":"..."}
  default_value   JSONB,
  placeholder     TEXT,
  unit            TEXT,

  -- Grid definition when input_kind='table_grid'
  grid_columns    JSONB,                -- [{"key":"bank","label":"Institution","kind":"short_text"}]
  grid_min_rows   INT,
  grid_max_rows   INT,

  -- Computation when input_kind='computed'
  compute_expr    TEXT,                 -- SQL-ish expr over sibling inputs

  -- RISK CONTRIBUTION
  risk_weight     NUMERIC(5,2) NOT NULL DEFAULT 0,
  risk_rule       JSONB,                -- {"type":"map","map":{"no":5,"partial":3,"yes":0}}

  -- FOLLOW-ON
  triggers_finding_when JSONB,          -- {"op":"eq","value":"no"}
  finding_template TEXT,
  requires_note_when JSONB,
  requires_document_when JSONB,

  show_when       JSONB,

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_input_code UNIQUE (section_id, input_code)
);
CREATE INDEX ix_input_section ON inst.input (section_id, sort_order);
