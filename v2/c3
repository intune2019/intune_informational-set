## SECTION 2: SPOKE — ROLES (contributes, not owns)

This is the piece that solves the problem I flagged: the same human can be a beneficial owner of Client A *and* the signatory at Client B, and now they're one `party_id` that screening hits once.

```sql
-- ============================================================
-- 21_PARTY_ROLE
-- ============================================================

CREATE TABLE crm.party_role (
  party_role_id  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  party_id       UUID NOT NULL REFERENCES crm.party(party_id) ON DELETE CASCADE,
  role_kind      crm.role_kind NOT NULL,

  -- Context: the role is held *at* / *toward* another party
  context_party_id UUID REFERENCES crm.party(party_id) ON DELETE CASCADE,

  title          TEXT,
  is_primary     BOOLEAN NOT NULL DEFAULT false,
  ownership_pct  NUMERIC(5,2) CHECK (ownership_pct BETWEEN 0 AND 100),
  ownership_type TEXT CHECK (ownership_type IN ('direct','indirect','beneficial','voting')),

  -- Role-scoped operational fields
  client_number  TEXT,              -- populated only when role_kind='client'
  risk_rating    core.risk_rating,
  relationship_owner UUID REFERENCES core.app_user(user_id),
  onboarded_at   TIMESTAMPTZ,
  portal_user_id UUID REFERENCES core.app_user(user_id),

  effective_from DATE NOT NULL DEFAULT CURRENT_DATE,
  effective_to   DATE,

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',

  CONSTRAINT ck_role_not_self CHECK (context_party_id IS NULL OR context_party_id <> party_id),
  CONSTRAINT ck_role_dates    CHECK (effective_to IS NULL OR effective_to >= effective_from),
  -- Roles that require a context party
  CONSTRAINT ck_role_context CHECK (
    role_kind NOT IN ('contact','beneficial_owner','control_person','signatory')
    OR context_party_id IS NOT NULL),
  -- client_number only on client roles, and required there
  CONSTRAINT ck_client_number CHECK (
    (role_kind = 'client') = (client_number IS NOT NULL))
);

CREATE INDEX ix_prole_party   ON crm.party_role (party_id, role_kind);
CREATE INDEX ix_prole_context ON crm.party_role (context_party_id, role_kind)
  WHERE record_status = 'active';
CREATE UNIQUE INDEX uq_prole_client_number ON crm.party_role (client_number)
  WHERE client_number IS NOT NULL;
-- One active primary contact per organization
CREATE UNIQUE INDEX uq_prole_primary_contact
  ON crm.party_role (context_party_id, role_kind)
  WHERE is_primary AND role_kind = 'contact' AND record_status = 'active';
-- Non-overlapping role tenure
ALTER TABLE crm.party_role ADD CONSTRAINT ex_prole_overlap
  EXCLUDE USING gist (
    party_id WITH =,
    (role_kind::text) WITH =,
    COALESCE(context_party_id, '00000000-0000-0000-0000-000000000000'::uuid) WITH =,
    daterange(effective_from, effective_to, '[)') WITH &&
  ) WHERE (record_status = 'active');

COMMENT ON TABLE crm.party_role IS
  'SPOKE. Contributes role context to a party; never owns identity.
   A single party_id may hold many roles across many context parties —
   e.g. beneficial owner of Client A and signatory at Client B.';

-- Ownership beyond 100% at a given context is a data-integrity failure
CREATE OR REPLACE FUNCTION crm.fn_check_ownership_total()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_total NUMERIC;
BEGIN
  IF NEW.role_kind = 'beneficial_owner' AND NEW.ownership_pct IS NOT NULL THEN
    SELECT COALESCE(sum(ownership_pct), 0) INTO v_total
      FROM crm.party_role
     WHERE context_party_id = NEW.context_party_id
       AND role_kind = 'beneficial_owner'
       AND ownership_type = COALESCE(NEW.ownership_type, 'direct')
       AND record_status = 'active'
       AND effective_to IS NULL
       AND party_role_id <> COALESCE(NEW.party_role_id, '00000000-0000-0000-0000-000000000000'::uuid);

    IF v_total + NEW.ownership_pct > 100.01 THEN
      RAISE EXCEPTION
        'Beneficial ownership for party % totals %%% with this row; cannot exceed 100%%',
        NEW.context_party_id, v_total + NEW.ownership_pct;
    END IF;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_ownership_total
  BEFORE INSERT OR UPDATE ON crm.party_role
  FOR EACH ROW EXECUTE FUNCTION crm.fn_check_ownership_total();

-- ---------- ORG-TO-ORG STRUCTURE ----------
CREATE TABLE crm.party_relationship (
  relationship_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  parent_party_id UUID NOT NULL REFERENCES crm.party(party_id) ON DELETE CASCADE,
  child_party_id  UUID NOT NULL REFERENCES crm.party(party_id) ON DELETE CASCADE,
  relationship_type TEXT NOT NULL CHECK (relationship_type IN
                    ('parent','subsidiary','affiliate','jv','branch','division')),
  ownership_pct   NUMERIC(5,2),
  effective_from  DATE NOT NULL DEFAULT CURRENT_DATE,
  effective_to    DATE,
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT ck_prel_distinct CHECK (parent_party_id <> child_party_id)
);

-- Cycle prevention — A owns B owns A is a beneficial-ownership fiction
CREATE OR REPLACE FUNCTION crm.fn_prevent_ownership_cycle()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_cycle BOOLEAN;
BEGIN
  WITH RECURSIVE ancestry AS (
    SELECT parent_party_id, child_party_id, 1 AS depth
      FROM crm.party_relationship
     WHERE child_party_id = NEW.parent_party_id AND record_status = 'active'
    UNION ALL
    SELECT pr.parent_party_id, pr.child_party_id, a.depth + 1
      FROM crm.party_relationship pr
      JOIN ancestry a ON pr.child_party_id = a.parent_party_id
     WHERE pr.record_status = 'active' AND a.depth < 20
  )
  SELECT EXISTS (SELECT 1 FROM ancestry WHERE parent_party_id = NEW.child_party_id)
    INTO v_cycle;

  IF v_cycle THEN
    RAISE EXCEPTION 'Ownership cycle detected: % cannot be a parent of %',
      NEW.parent_party_id, NEW.child_party_id;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_no_ownership_cycle
  BEFORE INSERT OR UPDATE ON crm.party_relationship
  FOR EACH ROW EXECUTE FUNCTION crm.fn_prevent_ownership_cycle();

-- ---------- CONTACT POINTS ----------
CREATE TABLE crm.contact_point (
  contact_point_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  party_id     UUID NOT NULL REFERENCES crm.party(party_id) ON DELETE CASCADE,
  point_type   TEXT NOT NULL CHECK (point_type IN ('email','phone','mobile','fax','website')),
  value        TEXT NOT NULL,
  label        TEXT,
  is_primary   BOOLEAN NOT NULL DEFAULT false,
  is_verified  BOOLEAN NOT NULL DEFAULT false,
  verified_at  TIMESTAMPTZ,
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active'
);
CREATE UNIQUE INDEX uq_cp_primary ON crm.contact_point (party_id, point_type)
  WHERE is_primary AND record_status = 'active';
CREATE INDEX ix_cp_value ON crm.contact_point (lower(value));

