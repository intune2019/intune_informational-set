  line1 TEXT NOT NULL, line2 TEXT,
  city TEXT NOT NULL, state_province TEXT,
  postal_code TEXT, country_code CHAR(2) NOT NULL DEFAULT 'US',
  is_primary   BOOLEAN NOT NULL DEFAULT false,
