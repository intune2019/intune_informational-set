                CHECK (status IN ('open','investigating','filed','closed_no_file','continuing')),
  filed_at      TIMESTAMPTZ,
  fincen_bsa_id TEXT,
  investigator  UUID REFERENCES core.app_user(user_id),
  approved_by   UUID REFERENCES core.app_user(user_id),
  filing_due_at TIMESTAMPTZ GENERATED ALWAYS AS (detected_at + INTERVAL '30 days') STORED,
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT ck_sar_four_eyes CHECK (approved_by IS NULL OR approved_by <> investigator)
);

-- ---------- PRIVILEGED NOTES ----------
CREATE TABLE sensitive.privileged_note (
  note_id     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  tenant_id   UUID NOT NULL REFERENCES core.tenant(tenant_id),
  party_id    UUID REFERENCES crm.party(party_id) ON DELETE CASCADE,
  case_id     UUID,
  sar_id      UUID REFERENCES sensitive.sar_case(sar_id) ON DELETE CASCADE,
  note_type   TEXT NOT NULL CHECK (note_type IN
              ('attorney_client','work_product','investigation','whistleblower','internal_only')),
  body        TEXT NOT NULL,
  author_id   UUID NOT NULL REFERENCES core.app_user(user_id),
  privilege_asserted_by TEXT,
  created_at  TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- ---------- ACCESS LOG (every read of this schema) ----------
CREATE TABLE sensitive.access_log (
  access_id   BIGSERIAL PRIMARY KEY,
  actor_id    UUID,
  tenant_id   UUID,
  party_id    UUID,
  object_schema TEXT NOT NULL,
  object_table  TEXT NOT NULL,
  object_pk     TEXT,
  action      TEXT NOT NULL CHECK (action IN ('read','decrypt','write','export')),
  justification TEXT,
  request_id  TEXT,
  client_ip   INET,
  occurred_at TIMESTAMPTZ NOT NULL DEFAULT now()
) PARTITION BY RANGE (occurred_at);

CREATE INDEX ix_sensaccess_actor ON sensitive.access_log (actor_id, occurred_at DESC);
CREATE INDEX ix_sensaccess_party ON sensitive.access_log (party_id, occurred_at DESC);
REVOKE UPDATE, DELETE ON sensitive.access_log FROM PUBLIC;

