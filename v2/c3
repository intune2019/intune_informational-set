);
CREATE INDEX ix_indiv_pep ON crm.party_individual (is_pep) WHERE is_pep;

-- Subtype exclusivity: a party is exactly one kind
CREATE OR REPLACE FUNCTION crm.fn_enforce_subtype()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_kind crm.party_kind;
BEGIN
  SELECT party_kind INTO v_kind FROM crm.party WHERE party_id = NEW.party_id;
  IF TG_TABLE_NAME = 'party_organization' AND v_kind <> 'organization' THEN
    RAISE EXCEPTION 'party % is kind=% but an organization subtype row was inserted',
      NEW.party_id, v_kind;
  ELSIF TG_TABLE_NAME = 'party_individual' AND v_kind <> 'individual' THEN
    RAISE EXCEPTION 'party % is kind=% but an individual subtype row was inserted',
      NEW.party_id, v_kind;
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_subtype_org BEFORE INSERT OR UPDATE ON crm.party_organization
  FOR EACH ROW EXECUTE FUNCTION crm.fn_enforce_subtype();
CREATE TRIGGER trg_subtype_ind BEFORE INSERT OR UPDATE ON crm.party_individual
  FOR EACH ROW EXECUTE FUNCTION crm.fn_enforce_subtype();
