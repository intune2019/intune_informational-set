## SECTION 9: THE IMPORT LOADER — consistency across every framework you author

```sql
-- ============================================================
-- 58_LOADER :: one authoring format → identical structure every time
-- ============================================================

CREATE OR REPLACE FUNCTION inst.fn_import_instrument(p_def JSONB, p_actor UUID)
RETURNS UUID LANGUAGE plpgsql AS $$
DECLARE
  v_inst UUID; v_sect UUID; v_req UUID;
  sec JSONB; req JSONB; item JSONB; inp JSONB; auth JSONB;
BEGIN
  -- Structural validation before anything is written
  IF p_def->>'instrument_code' IS NULL OR p_def->>'framework_code' IS NULL THEN
    RAISE EXCEPTION 'Definition must include instrument_code and framework_code.';
  END IF;
  IF jsonb_array_length(coalesce(p_def->'sections','[]'::jsonb)) = 0 THEN
    RAISE EXCEPTION 'Definition contains no sections.';
  END IF;

  INSERT INTO inst.instrument (
    framework_id, instrument_code, version, title, purpose, core_question,
    scope_statement, intended_use, estimated_days, deliverables,
    report_template_code, created_by)
  SELECT f.framework_id, p_def->>'instrument_code',
         COALESCE((p_def->>'version')::int, 1),
         p_def->>'title', p_def->>'purpose', p_def->>'core_question',
         p_def->>'scope_statement', p_def->>'intended_use',
         (p_def->>'estimated_days')::int,
         ARRAY(SELECT jsonb_array_elements_text(p_def->'deliverables')),
         p_def->>'report_template_code', p_actor
    FROM frame.framework f
   WHERE f.framework_code = p_def->>'framework_code'
  RETURNING instrument_id INTO v_inst;

  IF v_inst IS NULL THEN
    RAISE EXCEPTION 'Framework % not found.', p_def->>'framework_code';
  END IF;

  FOR sec IN SELECT * FROM jsonb_array_elements(p_def->'sections') LOOP
    -- Consistency gate: every non-scoping section must declare authority
    IF sec->>'section_kind' NOT IN ('scoping','document_request')
       AND jsonb_array_length(coalesce(sec->'authorities','[]'::jsonb)) = 0 THEN
      RAISE EXCEPTION
        'Section %: fieldwork sections must declare at least one authority in "authorities". Fact-based means criteria are cited, not asserted.',
        sec->>'section_code';
    END IF;

    INSERT INTO inst.section (
      instrument_id, domain_id, section_code, title, section_kind, sort_order,
      purpose, what_we_assess, why_it_matters, review_criteria, criteria_refs,
      red_flags, good_practice, min_evidence_tier, evidence_guidance,
      sample_guidance, performed_by_role, client_role_required,
      requires_narrative, narrative_prompt, requires_conclusion,
      weight, is_key_section, na_permitted, created_by)
    SELECT v_inst, d.domain_id, sec->>'section_code', sec->>'title',
           (sec->>'section_kind')::inst.section_kind,
           COALESCE((sec->>'sort_order')::int, 0),
           sec->>'purpose', sec->>'what_we_assess', sec->>'why_it_matters',
           sec->>'review_criteria',
           ARRAY(SELECT jsonb_array_elements_text(coalesce(sec->'criteria_refs','[]'::jsonb))),
           ARRAY(SELECT jsonb_array_elements_text(coalesce(sec->'red_flags','[]'::jsonb))),
           sec->>'good_practice',
           COALESCE((sec->>'min_evidence_tier')::frame.evidence_tier, 'tier_ii'),
           sec->>'evidence_guidance', sec->>'sample_guidance',
           sec->>'performed_by_role', sec->>'client_role_required',
           COALESCE((sec->>'requires_narrative')::boolean, true),
           sec->>'narrative_prompt',
           COALESCE((sec->>'requires_conclusion')::boolean, false),
           COALESCE((sec->>'weight')::numeric, 1.0),
           COALESCE((sec->>'is_key_section')::boolean, false),
           COALESCE((sec->>'na_permitted')::boolean, true),
           p_actor
      FROM (SELECT 1) x
      LEFT JOIN frame.domain d
        ON d.domain_code = sec->>'domain_code'
       AND d.framework_id = (SELECT framework_id FROM inst.instrument WHERE instrument_id = v_inst)
    RETURNING section_id INTO v_sect;

    -- Authorities (must already exist in the registry — the loader will not invent law)
    FOR auth IN SELECT * FROM jsonb_array_elements(coalesce(sec->'authorities','[]'::jsonb)) LOOP
      INSERT INTO inst.section_authority (section_id, authority_id, relevance, applicability_note)
      SELECT v_sect, a.authority_id,
             COALESCE(auth->>'relevance','primary'), auth->>'note'
        FROM frame.authority a WHERE a.citation = auth->>'citation';
      IF NOT FOUND THEN
        RAISE EXCEPTION
          'Section %: authority "%" is not in frame.authority. Register it (verified) before import.',
          sec->>'section_code', auth->>'citation';
      END IF;
    END LOOP;

    -- Risk vectors
    INSERT INTO inst.section_risk_vector (section_id, vector_id)
    SELECT v_sect, rv.vector_id
      FROM jsonb_array_elements_text(coalesce(sec->'risk_vectors','[]'::jsonb)) v(code)
      JOIN frame.risk_vector rv ON rv.vector_code = v.code;

    -- Document requirements + their receipt checklists
    FOR req IN SELECT * FROM jsonb_array_elements(coalesce(sec->'documents','[]'::jsonb)) LOOP
      INSERT INTO inst.document_requirement (
        section_id, req_code, sort_order, document_name, description, doc_type,
        format_expected, period_covered, is_mandatory, alternatives_accepted,
        review_checklist, acceptance_criteria, common_deficiencies,
        evidence_tier, requested_from_role, lead_time_days, created_by)
      VALUES (
        v_sect, req->>'req_code', COALESCE((req->>'sort_order')::int,0),
        req->>'document_name', req->>'description', req->>'doc_type',
        req->>'format_expected', req->>'period_covered',
        COALESCE((req->>'is_mandatory')::boolean, true),
        req->>'alternatives_accepted',
        ARRAY(SELECT jsonb_array_elements_text(coalesce(req->'review_checklist','[]'::jsonb))),
        req->>'acceptance_criteria',
        ARRAY(SELECT jsonb_array_elements_text(coalesce(req->'common_deficiencies','[]'::jsonb))),
        COALESCE((req->>'evidence_tier')::frame.evidence_tier,'tier_ii'),
        req->>'requested_from_role', COALESCE((req->>'lead_time_days')::int,5), p_actor)
      RETURNING requirement_id INTO v_req;

      -- Receipt checklist items materialize as rows
      INSERT INTO inst.checklist_item (
        requirement_id, item_code, sort_order, item_text,
        exception_requires_note, exception_suggests_finding, created_by)
      SELECT v_req,
             (req->>'req_code') || '.C' || (row_number() OVER ())::text,
             (row_number() OVER ())::int * 10, t.txt, true, true, p_actor
        FROM jsonb_array_elements_text(coalesce(req->'review_checklist','[]'::jsonb)) t(txt);
    END LOOP;

    -- Section-level checklist items
    FOR item IN SELECT * FROM jsonb_array_elements(coalesce(sec->'checklist','[]'::jsonb)) LOOP
      INSERT INTO inst.checklist_item (
        section_id, item_code, sort_order, item_text, guidance, authority_id,
        result_kind, exception_requires_note, exception_requires_evidence,
        exception_suggests_finding, is_mandatory, created_by)
      SELECT v_sect, item->>'item_code', COALESCE((item->>'sort_order')::int,0),
             item->>'item_text', item->>'guidance',
             (SELECT authority_id FROM frame.authority WHERE citation = item->>'citation'),
             COALESCE(item->>'result_kind','yes_no_exception'),
             COALESCE((item->>'exception_requires_note')::boolean, true),
             COALESCE((item->>'exception_requires_evidence')::boolean, false),
             COALESCE((item->>'exception_suggests_finding')::boolean, true),
             COALESCE((item->>'is_mandatory')::boolean, true), p_actor;
    END LOOP;

    -- Inputs
    FOR inp IN SELECT * FROM jsonb_array_elements(coalesce(sec->'inputs','[]'::jsonb)) LOOP
      INSERT INTO inst.input (
        section_id, input_code, sort_order, label, help_text, assessor_guidance,
        input_kind, is_required, answered_by, options, validation, grid_columns,
        risk_weight, risk_rule, triggers_finding_when, finding_template, created_by)
      VALUES (
        v_sect, inp->>'input_code', COALESCE((inp->>'sort_order')::int,0),
        inp->>'label', inp->>'help_text', inp->>'assessor_guidance',
        (inp->>'input_kind')::inst.input_kind,
        COALESCE((inp->>'is_required')::boolean, true),
        COALESCE(inp->>'answered_by','assessor'),
        inp->'options', inp->'validation', inp->'grid_columns',
        COALESCE((inp->>'risk_weight')::numeric, 0),
        inp->'risk_rule', inp->'triggers_finding_when',
        inp->>'finding_template', p_actor);
    END LOOP;
  END LOOP;

  -- Instantiation of unpublished instruments is already blocked;
  -- publish is a deliberate second step:
  --   UPDATE inst.instrument SET is_published = true, published_at = now(),
  --          published_by = <actor> WHERE instrument_id = v_inst;
  RETURN v_inst;
END $$;
```

Also extend instantiation so **every checklist item materializes as an open result row** the moment an engagement starts — that's the completeness guarantee at time zero:

```sql
CREATE OR REPLACE FUNCTION inst.fn_instantiate_checklists(p_admin UUID)
RETURNS INT LANGUAGE plpgsql AS $$
DECLARE v_count INT;
BEGIN
  INSERT INTO inst.checklist_result (administration_id, item_id, section_response_id)
  SELECT p_admin, ci.item_id, sr.section_response_id
    FROM inst.administration a
    JOIN inst.section s ON s.instrument_id = a.instrument_id
    JOIN inst.section_response sr
      ON sr.section_id = s.section_id AND sr.administration_id = p_admin
    JOIN inst.checklist_item ci ON ci.section_id = s.section_id
   WHERE a.administration_id = p_admin AND ci.record_status = 'active'
  ON CONFLICT (administration_id, item_id) DO NOTHING;
  GET DIAGNOSTICS v_count = ROW_COUNT;

  INSERT INTO inst.checklist_result (administration_id, item_id, collection_id)
  SELECT p_admin, ci.item_id, dc.collection_id
    FROM inst.document_collection dc
    JOIN inst.checklist_item ci ON ci.requirement_id = dc.requirement_id
   WHERE dc.administration_id = p_admin AND ci.record_status = 'active'
  ON CONFLICT (administration_id, item_id) DO NOTHING;

  RETURN v_count;
END $$;
```

