CREATE OR REPLACE VIEW inst.v_examiner_worklist AS
SELECT
  a.administration_id, a.admin_number, a.status AS engagement_status,
  p.display_name AS client_name,
  s.section_code, s.title, s.section_kind, s.sort_order,
  sr.section_response_id, sr.state,
  g.open_inputs, g.open_checklist, g.open_documents,
  g.needs_narrative, g.needs_work_performed, g.needs_evidence, g.needs_finding,
  (g.open_inputs + g.open_checklist + g.open_documents
   + g.needs_narrative + g.needs_work_performed + g.needs_evidence + g.needs_finding) AS total_open,
  sr.rating, sr.section_risk_score, sr.performed_by, sr.reviewed_by
FROM inst.administration a
JOIN crm.party p ON p.party_id = a.party_id
JOIN inst.section_response sr ON sr.administration_id = a.administration_id
JOIN inst.section s ON s.section_id = sr.section_id
CROSS JOIN LATERAL (
  SELECT
    count(*) FILTER (WHERE gap_kind='input')          AS open_inputs,
    count(*) FILTER (WHERE gap_kind='checklist')      AS open_checklist,
    count(*) FILTER (WHERE gap_kind='document')       AS open_documents,
    count(*) FILTER (WHERE gap_kind='narrative')      AS needs_narrative,
    count(*) FILTER (WHERE gap_kind='work_performed') AS needs_work_performed,
    count(*) FILTER (WHERE gap_kind='evidence')       AS needs_evidence,
    count(*) FILTER (WHERE gap_kind='finding')        AS needs_finding
  FROM inst.fn_section_gaps(sr.section_response_id)
) g
WHERE a.record_status = 'active' AND sr.record_status = 'active';

-- The crosswalk deliverable: finding → authority → risk vector → evidence
CREATE OR REPLACE VIEW inst.v_crosswalk AS
SELECT
  a.admin_number, p.display_name AS client_name,
  f.finding_number, f.title AS finding_title, f.severity, f.rating, f.status,
  s.section_code,
  au.citation, au.short_name AS authority_name, au.authority_kind,
  fc.application_note,
  rv.vector_code, rv.vector_name, rv.category AS risk_category,
  ev.evidence_ref, ev.tier AS evidence_tier, ev.source AS evidence_source
FROM inst.finding f
JOIN inst.administration a ON a.administration_id = f.administration_id
JOIN crm.party p ON p.party_id = a.party_id
LEFT JOIN inst.section_response sr ON sr.section_response_id = f.section_response_id
LEFT JOIN inst.section s ON s.section_id = sr.section_id
LEFT JOIN inst.finding_criteria fc ON fc.finding_id = f.finding_id
LEFT JOIN frame.authority au ON au.authority_id = fc.authority_id
LEFT JOIN inst.finding_risk_vector frv ON frv.finding_id = f.finding_id
LEFT JOIN frame.risk_vector rv ON rv.vector_id = frv.vector_id
LEFT JOIN inst.finding_evidence fe ON fe.finding_id = f.finding_id
LEFT JOIN inst.evidence ev ON ev.evidence_id = fe.evidence_id
WHERE f.record_status = 'active';

-- Risk register deliverable
CREATE OR REPLACE VIEW inst.v_risk_register AS
SELECT
  a.admin_number, p.display_name AS client_name,
  rv.vector_code, rv.vector_name, rv.category, rv.fraud_element,
  ra.likelihood, ra.impact, ra.score, ra.velocity, ra.basis_narrative,
  count(DISTINCT f.finding_id) AS related_findings,
  au.citation AS grounding_authority
FROM inst.risk_assessment ra
JOIN inst.administration a ON a.administration_id = ra.administration_id
JOIN crm.party p ON p.party_id = a.party_id
JOIN frame.risk_vector rv ON rv.vector_id = ra.vector_id
LEFT JOIN frame.authority au ON au.authority_id = rv.authority_id
LEFT JOIN inst.finding_risk_vector frv ON frv.vector_id = ra.vector_id
LEFT JOIN inst.finding f ON f.finding_id = frv.finding_id
  AND f.administration_id = ra.administration_id
WHERE ra.record_status = 'active'
GROUP BY a.admin_number, p.display_name, rv.vector_code, rv.vector_name,
         rv.category, rv.fraud_element, ra.likelihood, ra.impact, ra.score,
         ra.velocity, ra.basis_narrative, au.citation;
```

