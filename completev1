## SECTION 1: AUTHORITY REGISTRY — the crosswalk target

"Fact-based crosswalk to statute and law" means criteria are **foreign keys to citable authority, never free text.** An assessor cannot write a finding whose criteria is vibes.

```sql
-- ============================================================
-- 50_AUTHORITY :: statute, regulation, standard, guidance
-- ============================================================

CREATE TYPE frame.authority_kind AS ENUM (
  'statute',            -- 31 U.S.C. § 5318(h)
  'regulation',         -- 31 CFR 1010.230
  'state_statute',      -- Tex. Gov't Code ch. 2256
  'framework_standard', -- COSO Principle 10, NIST CSF GV.PO-01
  'exam_guidance',      -- FFIEC handbooks
  'professional_std',   -- IIA, ACFE, AICPA
  'contractual',        -- client policy, charter, indenture
  'internal_policy'     -- the client's own governing documents
);

CREATE TABLE frame.authority (
  authority_id    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  authority_kind  frame.authority_kind NOT NULL,
  citation        TEXT NOT NULL,          -- 'Tex. Gov''t Code § 2256.005(b)'
  short_name      TEXT NOT NULL,          -- 'PFIA — investment policy requirement'
  issuing_body    TEXT NOT NULL,          -- 'Texas Legislature'
  title_text      TEXT,                   -- verbatim heading where public domain
  requirement_summary TEXT NOT NULL,      -- neutral summary of what it requires
  url             TEXT,
  effective_date  DATE,
  superseded_by   UUID REFERENCES frame.authority(authority_id),
  verification_status TEXT NOT NULL DEFAULT 'verified'
                  CHECK (verification_status IN ('verified','pending_verification','superseded')),
  verified_by     UUID REFERENCES core.app_user(user_id),
  verified_at     TIMESTAMPTZ,
  is_licensed_content BOOLEAN NOT NULL DEFAULT false,  -- ISO/PCI/ACFE: cite ref only
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_citation UNIQUE (citation)
);
CREATE INDEX ix_authority_kind ON frame.authority (authority_kind, record_status);

COMMENT ON TABLE frame.authority IS
  'Every criteria in every finding traces here by FK. Free-text criteria are
   structurally impossible. Licensed standards store the citation and a neutral
   summary, never reproduced text.';

-- Section-level crosswalk: what a section tests against, declared up front
CREATE TABLE inst.section_authority (
  section_id    UUID NOT NULL REFERENCES inst.section(section_id) ON DELETE CASCADE,
  authority_id  UUID NOT NULL REFERENCES frame.authority(authority_id),
  relevance     TEXT NOT NULL DEFAULT 'primary'
                CHECK (relevance IN ('primary','supporting','informational')),
  applicability_note TEXT,   -- 'Applies only to TX public entities'
  PRIMARY KEY (section_id, authority_id)
);

-- Applicability rules: not every authority binds every client
CREATE TABLE frame.authority_applicability (
  applicability_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  authority_id  UUID NOT NULL REFERENCES frame.authority(authority_id) ON DELETE CASCADE,
  condition_expr JSONB NOT NULL,
  -- {"all":[{"field":"entity_type","op":"in","value":["government"]},
  --         {"field":"jurisdiction","op":"eq","value":"TX"}]}
  rationale     TEXT NOT NULL
);
```

## SECTION 2: RISK VECTOR ENGINE

```sql
-- ============================================================
-- 51_RISK_VECTOR
-- ============================================================

CREATE TABLE frame.risk_vector (
  vector_id     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  vector_code   TEXT NOT NULL UNIQUE,     -- 'TRE-LIQ', 'FRD-OPP'
  vector_name   TEXT NOT NULL,
  category      TEXT NOT NULL CHECK (category IN
                ('treasury','fraud','governance','compliance','operational',
                 'technology','third_party','reputational','strategic')),
  description   TEXT NOT NULL,
  -- Fraud-triangle tagging where category='fraud'
  fraud_element TEXT CHECK (fraud_element IN ('pressure','opportunity','rationalization')),
  authority_id  UUID REFERENCES frame.authority(authority_id),  -- where the vector is grounded
  velocity_default TEXT CHECK (velocity_default IN ('slow','moderate','rapid','immediate')),
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active'
);

-- Sections declare which vectors they probe — the instrument's risk coverage map
CREATE TABLE inst.section_risk_vector (
  section_id  UUID NOT NULL REFERENCES inst.section(section_id) ON DELETE CASCADE,
  vector_id   UUID NOT NULL REFERENCES frame.risk_vector(vector_id),
  PRIMARY KEY (section_id, vector_id)
);

-- Assessed exposure per administration per vector — feeds the Risk Register deliverable
CREATE TABLE inst.risk_assessment (
  risk_assessment_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  administration_id UUID NOT NULL REFERENCES inst.administration(administration_id) ON DELETE CASCADE,
  vector_id     UUID NOT NULL REFERENCES frame.risk_vector(vector_id),
  likelihood    INT NOT NULL CHECK (likelihood BETWEEN 1 AND 5),
  impact        INT NOT NULL CHECK (impact BETWEEN 1 AND 5),
  velocity      TEXT NOT NULL CHECK (velocity IN ('slow','moderate','rapid','immediate')),
  score         INT GENERATED ALWAYS AS (likelihood * impact) STORED,
  basis_narrative TEXT NOT NULL,          -- fact basis, mandatory
  assessed_by   UUID NOT NULL REFERENCES core.app_user(user_id),
  assessed_at   TIMESTAMPTZ NOT NULL DEFAULT now(),
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_admin_vector UNIQUE (administration_id, vector_id),
  CONSTRAINT ck_basis_substantive CHECK (length(trim(basis_narrative)) >= 100)
);

-- Evidence anchoring: a risk score must cite at least one section response
CREATE TABLE inst.risk_basis (
  risk_assessment_id UUID NOT NULL REFERENCES inst.risk_assessment(risk_assessment_id) ON DELETE CASCADE,
  section_response_id UUID NOT NULL REFERENCES inst.section_response(section_response_id),
  PRIMARY KEY (risk_assessment_id, section_response_id)
);

CREATE OR REPLACE FUNCTION inst.fn_risk_requires_basis()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM inst.risk_basis
                  WHERE risk_assessment_id = NEW.risk_assessment_id) THEN
    RAISE EXCEPTION
      'Risk vector scoring requires at least one section response as fact basis. Link the fieldwork first (inst.risk_basis).';
  END IF;
  RETURN NEW;
END $$;

-- Fires on UPDATE (record is created, basis linked, then finalized)
CREATE TRIGGER trg_risk_basis
  BEFORE UPDATE OF likelihood, impact ON inst.risk_assessment
  FOR EACH ROW WHEN (OLD.record_status = 'active')
  EXECUTE FUNCTION inst.fn_risk_requires_basis();
```

