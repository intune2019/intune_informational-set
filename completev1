  sort_order    INT NOT NULL DEFAULT 0,
  item_text     TEXT NOT NULL,            -- 'Is the policy authorized by the ultimate governing authority?'
  guidance      TEXT,
  authority_id  UUID REFERENCES frame.authority(authority_id),  -- what makes this item matter
  result_kind   TEXT NOT NULL DEFAULT 'yes_no_exception'
                CHECK (result_kind IN ('yes_no_exception','pass_fail','present_absent','verified_unverified')),
  exception_requires_note     BOOLEAN NOT NULL DEFAULT true,
  exception_requires_evidence BOOLEAN NOT NULL DEFAULT false,
  exception_suggests_finding  BOOLEAN NOT NULL DEFAULT true,
  is_mandatory  BOOLEAN NOT NULL DEFAULT true,
  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT ck_item_parent CHECK (num_nonnulls(section_id, requirement_id) = 1)
);
CREATE UNIQUE INDEX uq_item_code_section ON inst.checklist_item (section_id, item_code)
  WHERE section_id IS NOT NULL;
CREATE UNIQUE INDEX uq_item_code_req ON inst.checklist_item (requirement_id, item_code)
  WHERE requirement_id IS NOT NULL;

CREATE TABLE inst.checklist_result (
  result_id     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  administration_id UUID NOT NULL REFERENCES inst.administration(administration_id) ON DELETE CASCADE,
  item_id       UUID NOT NULL REFERENCES inst.checklist_item(item_id),
  section_response_id UUID REFERENCES inst.section_response(section_response_id) ON DELETE CASCADE,
  collection_id UUID REFERENCES inst.document_collection(collection_id) ON DELETE CASCADE,

  result        TEXT CHECK (result IN ('yes','no','exception','pass','fail',
                                       'present','absent','verified','unverified','na')),
  note          TEXT,
  na_rationale  TEXT,
  evidence_id   UUID REFERENCES inst.evidence(evidence_id),

  checked_by    UUID REFERENCES core.app_user(user_id),
  checked_at    TIMESTAMPTZ,

  created_by UUID, created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_by UUID, updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  record_status core.record_status NOT NULL DEFAULT 'active',
  CONSTRAINT uq_checklist_result UNIQUE (administration_id, item_id),
  CONSTRAINT ck_na_needs_rationale CHECK (result <> 'na' OR na_rationale IS NOT NULL)
);
CREATE INDEX ix_clresult_open ON inst.checklist_result (administration_id)
  WHERE result IS NULL;

-- Exception discipline: a negative result cannot be silently checked
CREATE OR REPLACE FUNCTION inst.fn_checklist_discipline()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE it RECORD;
BEGIN
  IF NEW.result IS NULL THEN RETURN NEW; END IF;

  SELECT * INTO it FROM inst.checklist_item WHERE item_id = NEW.item_id;

  IF NEW.result IN ('no','exception','fail','absent','unverified') THEN
    IF it.exception_requires_note AND coalesce(trim(NEW.note),'') = '' THEN
      RAISE EXCEPTION
        'Checklist %: a negative result requires a note stating what was observed. Silence is not a record.',
        it.item_code;
    END IF;
    IF it.exception_requires_evidence AND NEW.evidence_id IS NULL THEN
      RAISE EXCEPTION
        'Checklist %: this exception must link the evidence item that demonstrates it.',
        it.item_code;
    END IF;
  END IF;

  NEW.checked_by := COALESCE(NEW.checked_by, core.current_actor());
  NEW.checked_at := COALESCE(NEW.checked_at, now());
  RETURN NEW;
END $$;

CREATE TRIGGER trg_checklist_discipline
  BEFORE INSERT OR UPDATE ON inst.checklist_result
  FOR EACH ROW EXECUTE FUNCTION inst.fn_checklist_discipline();
```

## SECTION 4: THE COMPLETENESS STATE MACHINE

"Impossible to not collect all needed data points" — enforced as a gate function that computes what's missing, and a transition trigger that refuses advancement until the answer is nothing.

```sql
-- ============================================================
-- 53_COMPLETENESS
-- ============================================================

CREATE OR REPLACE FUNCTION inst.fn_section_gaps(p_section_response UUID)
RETURNS TABLE (gap_kind TEXT, gap_ref TEXT, gap_detail TEXT)
LANGUAGE sql STABLE AS $$
  -- 1. Unanswered required inputs
  SELECT 'input', i.input_code, i.label
    FROM inst.section_response sr
    JOIN inst.input i ON i.section_id = sr.section_id
    LEFT JOIN inst.input_response ir
      ON ir.input_id = i.input_id AND ir.section_response_id = sr.section_response_id
   WHERE sr.section_response_id = p_section_response
     AND i.is_required AND i.record_status = 'active'
     AND (ir.value_json IS NULL OR coalesce(ir.value_json->>'v','') = '')
  UNION ALL
  -- 2. Unchecked mandatory checklist items
  SELECT 'checklist', ci.item_code, ci.item_text
    FROM inst.section_response sr
    JOIN inst.checklist_item ci ON ci.section_id = sr.section_id
    LEFT JOIN inst.checklist_result cr
      ON cr.item_id = ci.item_id AND cr.section_response_id = sr.section_response_id
   WHERE sr.section_response_id = p_section_response
     AND ci.is_mandatory AND ci.record_status = 'active'
     AND cr.result IS NULL
  UNION ALL
  -- 3. Unresolved mandatory documents
  SELECT 'document', dr.req_code, dr.document_name || ' — status: ' || COALESCE(dc.status,'requested')
    FROM inst.section_response sr
    JOIN inst.document_requirement dr ON dr.section_id = sr.section_id
    LEFT JOIN inst.document_collection dc
      ON dc.requirement_id = dr.requirement_id AND dc.administration_id = sr.administration_id
   WHERE sr.section_response_id = p_section_response
     AND dr.is_mandatory AND dr.record_status = 'active'
     AND COALESCE(dc.status,'requested') NOT IN ('accepted','waived','not_available')
  UNION ALL
  -- 4. Missing narrative
  SELECT 'narrative', s.section_code, 'Professional narrative is required (min 150 chars)'
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.section_response_id = p_section_response
     AND s.requires_narrative
     AND length(coalesce(trim(sr.narrative),'')) < 150
  UNION ALL
  -- 5. Missing work-performed statement
  SELECT 'work_performed', s.section_code, 'Describe the procedures actually performed (min 100 chars)'
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.section_response_id = p_section_response
     AND s.section_kind NOT IN ('scoping','document_request')
     AND length(coalesce(trim(sr.work_performed),'')) < 100
  UNION ALL
  -- 6. Conclusion without sufficient evidence at the required tier
  SELECT 'evidence', s.section_code,
         'Rating requires sufficient evidence at ' || s.min_evidence_tier || ' or stronger'
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.section_response_id = p_section_response
     AND s.requires_conclusion
     AND NOT EXISTS (
       SELECT 1 FROM inst.evidence e
        WHERE e.section_response_id = sr.section_response_id
          AND e.is_sufficient IS TRUE AND e.tier <= s.min_evidence_tier)
  UNION ALL
  -- 7. Deficient rating without a finding
  SELECT 'finding', s.section_code,
         'A ' || sr.rating || ' rating requires at least one documented finding'
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.section_response_id = p_section_response
     AND sr.rating IN ('deficient','critical_exposure')
     AND NOT EXISTS (
       SELECT 1 FROM inst.finding f
        WHERE f.section_response_id = sr.section_response_id
          AND f.record_status = 'active');
$$;

-- Legal state transitions
CREATE TABLE inst.state_transition (
  from_state inst.completion_state NOT NULL,
  to_state   inst.completion_state NOT NULL,
  requires_gaps_clear BOOLEAN NOT NULL DEFAULT false,
  PRIMARY KEY (from_state, to_state)
);

INSERT INTO inst.state_transition VALUES
 ('not_started','in_progress', false),
 ('not_started','not_applicable', false),
 ('in_progress','client_pending', false),
 ('client_pending','in_progress', false),
 ('in_progress','ready_for_review', true),      -- THE GATE
 ('ready_for_review','reviewed', false),
 ('ready_for_review','reopened', false),
 ('reopened','in_progress', false),
 ('reviewed','complete', false),
 ('reviewed','reopened', false),
 ('in_progress','not_applicable', false),
 ('complete','reopened', false);

CREATE OR REPLACE FUNCTION inst.fn_enforce_transition()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_gaps INT; v_code TEXT; v_sample TEXT;
BEGIN
  IF OLD.state = NEW.state THEN RETURN NEW; END IF;

  IF NOT EXISTS (SELECT 1 FROM inst.state_transition
                  WHERE from_state = OLD.state AND to_state = NEW.state) THEN
    RAISE EXCEPTION 'Illegal state transition: % → %', OLD.state, NEW.state;
  END IF;

  IF EXISTS (SELECT 1 FROM inst.state_transition
              WHERE from_state = OLD.state AND to_state = NEW.state
                AND requires_gaps_clear) THEN
    SELECT count(*), min(gap_kind || ': ' || gap_ref)
      INTO v_gaps, v_sample
      FROM inst.fn_section_gaps(NEW.section_response_id);
    IF v_gaps > 0 THEN
      SELECT s.section_code INTO v_code FROM inst.section s WHERE s.section_id = NEW.section_id;
      RAISE EXCEPTION
        'Section % cannot advance: % open item(s). First: %. Query inst.fn_section_gaps(%L) for the full list.',
        v_code, v_gaps, v_sample, NEW.section_response_id;
    END IF;
  END IF;

  -- NA is a decision, not an escape
  IF NEW.state = 'not_applicable' THEN
    IF length(coalesce(trim(NEW.na_rationale),'')) < 100 THEN
      RAISE EXCEPTION 'Not-applicable requires a substantive rationale (min 100 chars).';
    END IF;
    IF NOT (SELECT na_permitted FROM inst.section WHERE section_id = NEW.section_id) THEN
      RAISE EXCEPTION 'This section may not be marked not-applicable.';
    END IF;
  END IF;

  -- Reopening a reviewed/complete section leaves a mark
  IF OLD.state IN ('reviewed','complete') AND NEW.state = 'reopened' THEN
    NEW.is_locked := false;
    NEW.review_notes := coalesce(NEW.review_notes,'') ||
      E'\n[REOPENED ' || now()::date || ' by ' || coalesce(core.current_actor()::text,'system') || ']';
  END IF;

  RETURN NEW;
END $$;

DROP TRIGGER IF EXISTS trg_inst_require_docs ON inst.section_response;
DROP TRIGGER IF EXISTS trg_inst_require_inputs ON inst.section_response;

CREATE TRIGGER trg_enforce_transition
  BEFORE UPDATE OF state ON inst.section_response
  FOR EACH ROW EXECUTE FUNCTION inst.fn_enforce_transition();
```

## SECTION 5: FINDING DISCIPLINE — condition / criteria / cause / effect, citation-required

```sql
-- ============================================================
-- 54_FINDING_DISCIPLINE
-- ============================================================

-- Criteria become FKs. The elements-of-a-finding structure (GAO Yellow Book
-- fieldwork discipline) is enforced, not encouraged.
CREATE TABLE inst.finding_criteria (
  finding_id    UUID NOT NULL REFERENCES inst.finding(finding_id) ON DELETE CASCADE,
  authority_id  UUID NOT NULL REFERENCES frame.authority(authority_id),
  application_note TEXT,   -- how this authority applies to this condition
  PRIMARY KEY (finding_id, authority_id)
);

CREATE TABLE inst.finding_evidence (
  finding_id   UUID NOT NULL REFERENCES inst.finding(finding_id) ON DELETE CASCADE,
  evidence_id  UUID NOT NULL REFERENCES inst.evidence(evidence_id),
  PRIMARY KEY (finding_id, evidence_id)
);

CREATE TABLE inst.finding_risk_vector (
  finding_id  UUID NOT NULL REFERENCES inst.finding(finding_id) ON DELETE CASCADE,
  vector_id   UUID NOT NULL REFERENCES frame.risk_vector(vector_id),
  PRIMARY KEY (finding_id, vector_id)
);

CREATE OR REPLACE FUNCTION inst.fn_finding_discipline()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  -- Draft findings may be skeletal; anything past draft must be complete
  IF NEW.status = 'draft' THEN RETURN NEW; END IF;

  IF length(coalesce(trim(NEW.condition),'')) < 100 THEN
    RAISE EXCEPTION 'Finding %: CONDITION must state what was observed, factually (min 100 chars).', NEW.finding_number;
  END IF;
  IF length(coalesce(trim(NEW.cause),'')) < 50 THEN
    RAISE EXCEPTION 'Finding %: CAUSE is required before the finding leaves draft.', NEW.finding_number;
  END IF;
  IF length(coalesce(trim(NEW.effect),'')) < 50 THEN
    RAISE EXCEPTION 'Finding %: EFFECT (actual or potential consequence) is required.', NEW.finding_number;
  END IF;
  IF length(coalesce(trim(NEW.recommendation),'')) < 50 THEN
    RAISE EXCEPTION 'Finding %: RECOMMENDATION must be actionable (min 50 chars).', NEW.finding_number;
  END IF;

  -- Criteria: at least one authority citation. Free text alone is not criteria.
  IF NOT EXISTS (SELECT 1 FROM inst.finding_criteria WHERE finding_id = NEW.finding_id) THEN
    RAISE EXCEPTION
      'Finding %: criteria must cite at least one authority (inst.finding_criteria). A finding without citable criteria is an opinion.',
      NEW.finding_number;
  END IF;

  -- Fact basis: at least one evidence link
  IF NOT EXISTS (SELECT 1 FROM inst.finding_evidence WHERE finding_id = NEW.finding_id) THEN
    RAISE EXCEPTION
      'Finding %: link the evidence demonstrating the condition (inst.finding_evidence).',
      NEW.finding_number;
  END IF;

  -- Risk traceability
  IF NOT EXISTS (SELECT 1 FROM inst.finding_risk_vector WHERE finding_id = NEW.finding_id) THEN
    RAISE EXCEPTION
      'Finding %: tag at least one risk vector so the Risk Register can aggregate it.',
      NEW.finding_number;
  END IF;

  RETURN NEW;
END $$;

CREATE TRIGGER trg_finding_discipline
  BEFORE UPDATE OF status ON inst.finding
  FOR EACH ROW EXECUTE FUNCTION inst.fn_finding_discipline();
```

## SECTION 6: ADMINISTRATION-LEVEL GATE — the report cannot issue incomplete

```sql
-- ============================================================
-- 55_ISSUANCE_GATE
-- ============================================================

CREATE OR REPLACE FUNCTION inst.fn_administration_gaps(p_admin UUID)
RETURNS TABLE (gap_kind TEXT, gap_ref TEXT, gap_detail TEXT)
LANGUAGE sql STABLE AS $$
  SELECT 'section', s.section_code, 'State: ' || sr.state
    FROM inst.section_response sr
    JOIN inst.section s ON s.section_id = sr.section_id
   WHERE sr.administration_id = p_admin
     AND sr.record_status = 'active'
     AND sr.state NOT IN ('complete','not_applicable')
  UNION ALL
  SELECT 'finding', f.finding_number, 'Finding still in status: ' || f.status
    FROM inst.finding f
   WHERE f.administration_id = p_admin
     AND f.record_status = 'active'
     AND f.status = 'draft'
  UNION ALL
  SELECT 'risk_register', rv.vector_code,
         'Vector probed by fieldwork but never scored'
    FROM inst.section_response sr
    JOIN inst.section_risk_vector srv ON srv.section_id = sr.section_id
    JOIN frame.risk_vector rv ON rv.vector_id = srv.vector_id
   WHERE sr.administration_id = p_admin AND sr.state = 'complete'
     AND NOT EXISTS (SELECT 1 FROM inst.risk_assessment ra
                      WHERE ra.administration_id = p_admin
                        AND ra.vector_id = srv.vector_id
                        AND ra.record_status = 'active')
   GROUP BY rv.vector_code
  UNION ALL
  SELECT 'language', lv.matched_term, 'Unresolved assurance-language violation'
    FROM inst.language_violation lv
   WHERE lv.administration_id = p_admin AND lv.resolved_at IS NULL
  UNION ALL
  SELECT 'continuity', 'signature',
         'Report signatory differs from proposal signatory without a recorded variance'
    FROM inst.administration a
    JOIN engage.engagement e ON e.engagement_id = a.engagement_id
    JOIN core.operating_profile op ON op.profile_id = a.profile_id
   WHERE a.administration_id = p_admin
     AND op.requires_continuity_trace
     AND EXISTS (
       SELECT 1 FROM engage.continuity_trace ct
        WHERE ct.engagement_id = e.engagement_id
          AND ct.lifecycle_stage = 'proposal'
          AND ct.asserted_by IS DISTINCT FROM e.report_signatory)
     AND NOT EXISTS (
       SELECT 1 FROM engage.continuity_trace ct
        WHERE ct.engagement_id = e.engagement_id
          AND ct.lifecycle_stage = 'report_signature'
          AND ct.variance_from_prior IS NOT NULL);
$$;

CREATE OR REPLACE FUNCTION inst.fn_gate_issuance()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE v_gaps INT; v_sample TEXT;
BEGIN
  IF NEW.status IN ('final') AND OLD.status <> 'final' THEN
    SELECT count(*), min(gap_kind || ': ' || gap_ref || ' — ' || gap_detail)
      INTO v_gaps, v_sample
      FROM inst.fn_administration_gaps(NEW.administration_id);
    IF v_gaps > 0 THEN
      RAISE EXCEPTION
        'Cannot finalize %: % open item(s). First: %. Query inst.fn_administration_gaps(%L).',
        NEW.admin_number, v_gaps, v_sample, NEW.administration_id;
    END IF;
    PERFORM inst.fn_roll_administration(NEW.administration_id);
    NEW.issued_at := now();
  END IF;
  RETURN NEW;
END $$;

CREATE TRIGGER trg_gate_issuance
  BEFORE UPDATE OF status ON inst.administration
  FOR EACH ROW EXECUTE FUNCTION inst.fn_gate_issuance();
```

## SECTION 7: THE UI CONTRACT — what the Examiner interface consumes

The interface designer never invents completeness logic. It's one view.

```sql
-- ============================================================
